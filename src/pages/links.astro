---
import Layout from '../layouts/Layout.astro';
import FloatingWhatsApp from '../components/FloatingWhatsApp.astro';

const title = 'Loja Parceira Ton Manaus | Todos os nossos canais';
const description = 'Todos os links da Loja Parceira Ton em Manaus: loja física, WhatsApp, condição Ton Black, análise gratuita da sua taxa e catálogo de maquininhas.';

const models = [
  { name: 'TapTon', img: '/ai-tapton.webp', price: 'Grátis', desc: 'Cartão no seu Android' },
  { name: 'T1', img: '/ai-t1.webp', price: '17', desc: 'Bluetooth com o celular' },
  { name: 'T2', img: '/ai-t2.webp', price: '40', desc: '3G e Wi-Fi próprios' },
  { name: 'T3', img: '/ai-t3.webp', price: '86', desc: 'Impressora e teclado' },
  { name: 'T3 Smart', img: '/ai-t3-smart.webp', price: '154', desc: 'Android e tela grande' }
];

const waLoja = (msg: string) => 'https://wa.me/lojatonmanaus?text=' + encodeURIComponent(msg);
const waConsult = (msg: string) => 'https://wa.me/5592981074692?text=' + encodeURIComponent(msg);

const mainLinks = [
  {
    title: 'Falar no WhatsApp da loja',
    subtitle: 'Atendimento humano, em Manaus',
    href: waLoja('Olá! Vim pela página de links da loja.'),
    icon: 'wa',
    highlight: true
  },
  {
    title: 'Ver o Plano Ton Black',
    subtitle: 'Condição pra quem fatura acima de R$ 20 mil/mês',
    href: '/ton-black',
    icon: 'arrow'
  },
  {
    title: 'Análise gratuita da minha taxa',
    subtitle: 'Descubra em minutos quanto você paga a mais',
    href: waConsult('Olá! Quero fazer a análise gratuita da minha taxa atual.'),
    icon: 'chart'
  },
  {
    title: 'Como chegar na loja',
    subtitle: 'Av. Eduardo Ribeiro, 520, Centro',
    href: 'https://maps.google.com/?q=Av.+Eduardo+Ribeiro+520+Manaus',
    icon: 'pin'
  },
  {
    title: 'Todos os modelos e planos',
    subtitle: 'Site completo',
    href: '/',
    icon: 'globe'
  }
];
---
<Layout title={title} description={description} path="/links">
  <main class="relative overflow-hidden">
    <!-- Fundo: fachada com overlay -->
    <div class="fixed inset-0 -z-10" aria-hidden="true">
      <img src="/diferencial.webp" alt="" class="absolute inset-0 h-full w-full object-cover blur-xl scale-110 opacity-40" />
      <div class="absolute inset-0 bg-gradient-to-b from-paper via-paper/95 to-paper"></div>
    </div>

    <div class="container-x max-w-lg py-10 md:py-14 mx-auto">
      <!-- Cabeçalho: logo + identificação -->
      <header class="text-center">
        <div class="inline-flex flex-col items-center">
          <div class="relative">
            <div class="absolute -inset-2 rounded-full bg-ton/25 blur-md" aria-hidden="true"></div>
            <div class="relative h-20 w-20 md:h-24 md:w-24 rounded-full bg-paper-pure border-4 border-paper-pure shadow-soft flex items-center justify-center p-3 overflow-hidden">
              <img src="/logo-ton.png" alt="Loja Parceira Ton" class="h-full w-full object-contain" />
            </div>
          </div>
          <h1 class="mt-5 font-display text-2xl md:text-3xl font-bold text-ink-950">Loja Parceira Ton Manaus</h1>
          <p class="mt-1 text-sm text-ink-500">Parceiro Autorizado Ton no Centro de Manaus</p>
          <span class="mt-4 chip bg-paper-pure" data-store-chip>
            <span class="h-1.5 w-1.5 rounded-full bg-ton animate-pulse" data-store-dot></span>
            <span data-store-status>Loja no Centro de Manaus</span>
            <span class="text-ink-500">· Seg a sex, 9h às 17h</span>
          </span>
        </div>
      </header>

      <!-- Foto da loja -->
      <div class="mt-8 rounded-3xl overflow-hidden border border-line bg-paper-pure shadow-card">
        <div class="aspect-[4/3] relative">
          <img src="/diferencial.webp" alt="Fachada da Loja Parceira Ton" class="absolute inset-0 h-full w-full object-cover" />
        </div>
      </div>

      <!-- Links principais -->
      <nav class="mt-8 space-y-3">
        {mainLinks.map((l) => (
          <a
            href={l.href}
            target={l.href.startsWith('http') ? '_blank' : undefined}
            rel={l.href.startsWith('http') ? 'noopener' : undefined}
            class:list={[
              'group flex items-center gap-4 rounded-2xl border p-4 md:p-5 transition-all duration-200',
              l.highlight
                ? 'bg-ton text-ink-950 border-ton hover:bg-ton-deep hover:text-paper hover:border-ton-deep shadow-glow'
                : 'bg-paper-pure border-line hover:border-ton/50 hover:-translate-y-0.5 hover:shadow-card'
            ]}
            data-cta={`links-${l.icon}`}
          >
            <span class:list={[
              'shrink-0 h-11 w-11 rounded-full flex items-center justify-center',
              l.highlight ? 'bg-ink-950 text-ton' : 'bg-ton-soft text-ton-deep'
            ]}>
              { l.icon === 'wa' && (
                <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M17.5 14.4c-.3-.1-1.7-.8-2-.9-.3-.1-.5-.2-.7.2-.2.3-.8.9-.9 1.1-.2.2-.3.2-.6.1s-1.2-.4-2.3-1.4c-.8-.7-1.4-1.6-1.5-1.9-.2-.3 0-.5.1-.6.1-.1.3-.3.4-.5.1-.2.2-.3.3-.5.1-.2 0-.4 0-.5 0-.1-.7-1.6-.9-2.2-.2-.6-.5-.5-.7-.5h-.6c-.2 0-.5.1-.8.4s-1 1-1 2.5.9 2.9 1.1 3.1c.1.2 2 3.1 4.9 4.3.7.3 1.2.5 1.6.6.7.2 1.3.2 1.8.1.5-.1 1.7-.7 1.9-1.4.2-.7.2-1.3.2-1.4-.1-.2-.3-.2-.7-.4zM12 2.2C6.6 2.2 2.2 6.6 2.2 12c0 1.7.4 3.3 1.2 4.7L2 22l5.5-1.4C8.9 21.4 10.4 21.8 12 21.8c5.4 0 9.8-4.4 9.8-9.8S17.4 2.2 12 2.2z"/></svg>
              )}
              { l.icon === 'arrow' && (
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
              )}
              { l.icon === 'chart' && (
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3v18h18"/><path d="M18 17V9m-5 8V5m-5 12v-4"/></svg>
              )}
              { l.icon === 'pin' && (
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
              )}
              { l.icon === 'globe' && (
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
              )}
            </span>
            <span class="flex-1 min-w-0">
              <span class="block font-display font-semibold leading-tight">{l.title}</span>
              <span class:list={[
                'block text-xs mt-0.5',
                l.highlight ? 'text-ink-950/70 group-hover:text-paper/80' : 'text-ink-500'
              ]}>{l.subtitle}</span>
            </span>
            <svg class="shrink-0 opacity-60" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M9 6l6 6-6 6"/></svg>
          </a>
        ))}
      </nav>

      <!-- Catálogo rápido -->
      <section class="mt-12">
        <div class="text-center max-w-md mx-auto">
          <span class="eyebrow">Catálogo rápido</span>
          <h2 class="mt-2 font-display text-2xl md:text-3xl font-bold text-ink-950 leading-tight">
            Qual maquininha você quer?
          </h2>
          <p class="mt-2 text-sm text-ink-500">
            Toca no modelo e a gente já te chama no WhatsApp.
          </p>
        </div>

        <div class="mt-6 flex gap-3 overflow-x-auto snap-x snap-mandatory scrollbar-hide -mx-5 px-5 pb-4">
          {models.map((m) => {
            const wa = waLoja(`Olá! Vim da página de links e quero a maquininha ${m.name}.`);
            return (
              <a
                href={wa}
                target="_blank"
                rel="noopener"
                class="group shrink-0 w-[70%] sm:w-[42%] snap-start flex flex-col rounded-2xl bg-paper-pure border border-line p-4 hover:border-ton/50 hover:shadow-card transition-all"
                data-cta={`links-modelo-${m.name.toLowerCase().replace(/\s+/g,'-')}`}
              >
                <div class="aspect-square w-full rounded-xl bg-paper-soft flex items-center justify-center overflow-hidden">
                  <img src={m.img} alt={`Maquininha Ton ${m.name}`} class="max-h-full max-w-full object-contain" loading="lazy" />
                </div>
                <div class="mt-4 flex-1">
                  <div class="font-display text-lg font-semibold text-ink-950">{m.name}</div>
                  <div class="text-xs text-ton-deep font-medium">{m.desc}</div>
                </div>
                <div class="mt-3 pt-3 border-t border-line flex items-end justify-between">
                  <div>
                    <div class="text-[10px] text-ink-500 uppercase tracking-wider">a partir de</div>
                    <div class="font-display text-xl font-bold text-ink-950 leading-none">
                      {m.price === 'Grátis' ? 'Grátis' : `R$ ${m.price}`}
                    </div>
                  </div>
                  <span class="shrink-0 h-9 w-9 rounded-full bg-ton flex items-center justify-center text-ink-950 group-hover:bg-ton-deep group-hover:text-paper transition-colors">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M17.5 14.4c-.3-.1-1.7-.8-2-.9-.3-.1-.5-.2-.7.2-.2.3-.8.9-.9 1.1-.2.2-.3.2-.6.1s-1.2-.4-2.3-1.4c-.8-.7-1.4-1.6-1.5-1.9-.2-.3 0-.5.1-.6.1-.1.3-.3.4-.5.1-.2.2-.3.3-.5.1-.2 0-.4 0-.5 0-.1-.7-1.6-.9-2.2-.2-.6-.5-.5-.7-.5h-.6c-.2 0-.5.1-.8.4s-1 1-1 2.5.9 2.9 1.1 3.1c.1.2 2 3.1 4.9 4.3.7.3 1.2.5 1.6.6.7.2 1.3.2 1.8.1.5-.1 1.7-.7 1.9-1.4.2-.7.2-1.3.2-1.4-.1-.2-.3-.2-.7-.4zM12 2.2C6.6 2.2 2.2 6.6 2.2 12c0 1.7.4 3.3 1.2 4.7L2 22l5.5-1.4C8.9 21.4 10.4 21.8 12 21.8c5.4 0 9.8-4.4 9.8-9.8S17.4 2.2 12 2.2z"/></svg>
                  </span>
                </div>
              </a>
            );
          })}
        </div>

        <!-- Indicador visual "arrasta pro lado" -->
        <div class="mt-2 flex items-center justify-center gap-2 text-[10px] uppercase tracking-widest text-ink-500">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M15 6l-6 6 6 6"/></svg>
          <span>arrasta pra ver todas</span>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M9 6l6 6-6 6"/></svg>
        </div>
      </section>

      <!-- Rodapé -->
      <footer class="mt-14 pt-8 border-t border-line text-center">
        <div class="text-xs text-ink-500 leading-relaxed space-y-3">
          <strong class="text-ink-700 block">Loja Parceira Ton Manaus</strong>
          <div>
            <div class="text-[10px] uppercase tracking-widest text-ton-deep font-mono">Unidade Centro</div>
            Av. Eduardo Ribeiro, 520, Sala 02, Ed. Manaus Shopping Center
          </div>
          <div>
            <div class="text-[10px] uppercase tracking-widest text-ton-deep font-mono">Unidade Cidade Nova</div>
            Rua Felix Valois, 41, Cidade Nova, perto da Blue Fit
          </div>
        </div>
        <p class="mt-6 text-[10px] text-ink-500 leading-relaxed max-w-md mx-auto">
          Este canal é de titularidade de um Parceiro Renda Ton. "Ton" é marca registrada da
          STONE INSTITUIÇÃO DE PAGAMENTO S.A.
        </p>
        <p class="mt-4 flex flex-wrap justify-center gap-x-4 gap-y-1 text-[11px] text-ink-500">
          <a href="/privacidade" class="hover:text-ink-700 link-underline">Privacidade</a>
          <a href="/termos" class="hover:text-ink-700 link-underline">Termos</a>
        </p>
      </footer>
    </div>
  </main>
</Layout>
