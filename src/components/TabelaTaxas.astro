---
// Modal com as tabelas oficiais de taxas (Ton Black e Ton Mega+), em HTML nativo.
export interface Props {
  variant?: 'light' | 'dark';
  label?: string;
  defaultTab?: 'black' | 'mega';
}
const { variant = 'light', label = 'Ver tabela completa de taxas', defaultTab = 'black' } = Astro.props;
const isDark = variant === 'dark';
const blackFirst = defaultTab === 'black';

const black = {
  faixas: ['R$ 0 a R$ 20 mil', 'R$ 20 a R$ 40 mil', 'R$ 40 a R$ 80 mil', 'Acima de R$ 80 mil'],
  destaque: 3,
  linhas: [
    ['Débito', '1,36%', '0,84%', '0,78%', '0,74%'],
    ['Crédito à vista', '3,14%', '2,88%', '2,78%', '2,68%'],
    ['2x', '5,38%', '4,21%', '4,07%', '3,93%'],
    ['3x', '6,11%', '4,82%', '4,64%', '4,45%'],
    ['4x', '6,84%', '5,43%', '5,20%', '4,97%'],
    ['5x', '7,56%', '6,04%', '5,76%', '5,48%'],
    ['6x', '8,27%', '6,63%', '6,31%', '5,98%'],
    ['7x', '8,98%', '7,23%', '6,86%', '6,50%'],
    ['8x', '9,68%', '7,81%', '7,41%', '6,98%'],
    ['9x', '10,37%', '8,40%', '7,95%', '7,50%'],
    ['10x', '11,05%', '8,97%', '8,48%', '7,98%'],
    ['11x', '11,73%', '9,55%', '9,02%', '8,48%'],
    ['12x', '12,39%', '10,11%', '9,55%', '8,98%'],
    ['13x', '15,39%', '13,11%', '12,55%', '11,98%'],
    ['14x', '16,01%', '13,63%', '13,05%', '12,46%'],
    ['15x', '16,65%', '14,18%', '13,57%', '12,96%'],
    ['16x', '17,31%', '14,75%', '14,12%', '13,48%'],
    ['17x', '18,00%', '15,34%', '14,68%', '14,01%'],
    ['18x', '18,72%', '15,95%', '15,27%', '14,58%'],
    ['19x', '19,36%', '16,59%', '15,91%', '15,22%'],
    ['20x', '20,00%', '17,23%', '16,55%', '15,86%'],
    ['21x', '20,64%', '17,87%', '17,19%', '16,50%'],
  ],
  pix: ['Pix', '0%', '0%', '0%', '0%']
};

const mega = {
  faixas: ['Promocional', 'Até R$ 3 mil', 'R$ 3 a R$ 6 mil', 'R$ 6 a R$ 10 mil', 'R$ 10 a R$ 30 mil', 'Acima de R$ 30 mil'],
  destaque: 0,
  linhas: [
    ['Débito', '2,57%', '2,98%', '2,68%', '2,61%', '2,51%', '2,48%'],
    ['Crédito à vista', '4,34%', '5,15%', '4,63%', '4,54%', '4,31%', '4,14%'],
    ['2x', '7,02%', '11,30%', '8,73%', '8,13%', '6,82%', '6,77%'],
    ['3x', '7,58%', '12,68%', '9,79%', '9,20%', '7,55%', '7,50%'],
    ['4x', '8,38%', '14,03%', '10,67%', '10,08%', '9,28%', '9,23%'],
    ['5x', '9,38%', '15,36%', '11,54%', '10,95%', '10,00%', '9,95%'],
    ['6x', '10,38%', '16,66%', '12,29%', '11,81%', '10,71%', '10,66%'],
    ['7x', '10,98%', '17,94%', '12,34%', '12,31%', '11,42%', '11,37%'],
    ['8x', '11,38%', '19,20%', '12,39%', '12,36%', '12,12%', '12,07%'],
    ['9x', '12,38%', '20,43%', '12,44%', '12,41%', '12,38%', '12,35%'],
    ['10x', '12,88%', '21,78%', '12,64%', '12,61%', '12,58%', '12,55%'],
    ['11x', '13,74%', '22,64%', '13,98%', '13,95%', '13,92%', '13,71%'],
    ['12x', '13,78%', '22,68%', '14,67%', '14,64%', '14,02%', '13,80%'],
    ['13x', '14,87%', '23,32%', '15,31%', '15,28%', '14,66%', '14,44%'],
    ['14x', '15,51%', '23,96%', '15,95%', '15,92%', '15,30%', '15,08%'],
    ['15x', '16,15%', '24,60%', '16,59%', '16,56%', '15,94%', '15,72%'],
    ['16x', '16,79%', '25,24%', '17,23%', '17,20%', '16,58%', '16,36%'],
    ['17x', '17,43%', '25,88%', '17,87%', '17,84%', '17,22%', '17,00%'],
    ['18x', '18,07%', '26,52%', '18,51%', '18,48%', '17,86%', '17,64%'],
  ],
  pix: ['Pix', '0%', '0%', '0%', '0%', '0%', '0%']
};
---
<div class="inline-block" data-taxas-root>
<button
  type="button"
  class:list={['btn', isDark ? 'btn-wa' : 'btn-ghost']}
  data-taxas-open
>
  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/>
  </svg>
  {label}
</button>

<dialog class="taxas-dialog" data-taxas-dialog aria-label="Tabelas de taxas Ton">
  <div class="taxas-inner">
    <header class="taxas-header">
      <div>
        <div class="taxas-eyebrow">Tabelas oficiais · Recebimento em 1 dia útil</div>
        <h3 class="taxas-title">Taxas por faixa de faturamento</h3>
      </div>
      <button type="button" class="taxas-close" data-taxas-close aria-label="Fechar">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M18 6L6 18M6 6l12 12"/></svg>
      </button>
    </header>

    <div class="taxas-tabs" role="tablist">
      <button type="button" class:list={['taxas-tab', blackFirst && 'is-active']} data-taxas-tab="black" role="tab">Ton Black</button>
      <button type="button" class:list={['taxas-tab', !blackFirst && 'is-active']} data-taxas-tab="mega" role="tab">Ton Mega+</button>
    </div>

    <div class="taxas-body">
      <!-- TON BLACK -->
      <div class:list={['taxas-panel', blackFirst && 'is-active']} data-taxas-panel="black">
        <p class="taxas-panel-note">
          Exclusivo para <strong>MEI e CNPJ</strong>. Quanto maior o seu faturamento, menor a taxa.
        </p>
        <div class="taxas-scroll">
          <table class="taxas-table">
            <thead>
              <tr>
                <th scope="col" class="col-label">Recebimento</th>
                {black.faixas.map((f, i) => (
                  <th scope="col" class:list={[i === black.destaque ? 'is-best' : '']}>
                    {f}
                    {i === black.destaque && <span class="best-badge">melhor taxa</span>}
                  </th>
                ))}
              </tr>
            </thead>
            <tbody>
              {black.linhas.map(([label, ...vals]) => (
                <tr>
                  <th scope="row" class="col-label">{label}</th>
                  {vals.map((v, i) => (
                    <td class:list={[i === black.destaque ? 'is-best' : '']}>{v}</td>
                  ))}
                </tr>
              ))}
              <tr class="row-pix">
                <th scope="row" class="col-label">{black.pix[0]}</th>
                {black.pix.slice(1).map((v) => (<td>{v}</td>))}
              </tr>
            </tbody>
          </table>
        </div>
      </div>

      <!-- TON MEGA+ -->
      <div class:list={['taxas-panel', !blackFirst && 'is-active']} data-taxas-panel="mega">
        <p class="taxas-panel-note">
          Aceita <strong>CPF e CNPJ</strong>. A faixa promocional vale no começo, depois a taxa passa a seguir o seu faturamento.
        </p>
        <div class="taxas-scroll">
          <table class="taxas-table">
            <thead>
              <tr>
                <th scope="col" class="col-label">Recebimento</th>
                {mega.faixas.map((f, i) => (
                  <th scope="col" class:list={[i === mega.destaque ? 'is-best' : '']}>
                    {f}
                    {i === mega.destaque && <span class="best-badge">promo</span>}
                  </th>
                ))}
              </tr>
            </thead>
            <tbody>
              {mega.linhas.map(([label, ...vals]) => (
                <tr>
                  <th scope="row" class="col-label">{label}</th>
                  {vals.map((v, i) => (
                    <td class:list={[i === mega.destaque ? 'is-best' : '']}>{v}</td>
                  ))}
                </tr>
              ))}
              <tr class="row-pix">
                <th scope="row" class="col-label">{mega.pix[0]}</th>
                {mega.pix.slice(1).map((v) => (<td>{v}</td>))}
              </tr>
            </tbody>
          </table>
        </div>
      </div>
    </div>

    <footer class="taxas-footer">
      <p>
        Tabelas oficiais do Ton, sujeitas a alteração pela operadora. A condição final depende do plano
        contratado, do seu faturamento e das políticas vigentes. Fazemos a simulação personalizada no atendimento.
      </p>
      <a
        href="https://wa.me/lojatonmanaus?text=Ol%C3%A1!%20Vi%20a%20tabela%20de%20taxas%20no%20site%20e%20quero%20uma%20simula%C3%A7%C3%A3o."
        target="_blank" rel="noopener"
        class="btn btn-wa w-full sm:w-auto shrink-0"
        data-cta="tabela-taxas-wa"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.5 14.4c-.3-.1-1.7-.8-2-.9-.3-.1-.5-.2-.7.2-.2.3-.8.9-.9 1.1-.2.2-.3.2-.6.1s-1.2-.4-2.3-1.4c-.8-.7-1.4-1.6-1.5-1.9-.2-.3 0-.5.1-.6.1-.1.3-.3.4-.5.1-.2.2-.3.3-.5.1-.2 0-.4 0-.5 0-.1-.7-1.6-.9-2.2-.2-.6-.5-.5-.7-.5h-.6c-.2 0-.5.1-.8.4s-1 1-1 2.5.9 2.9 1.1 3.1c.1.2 2 3.1 4.9 4.3.7.3 1.2.5 1.6.6.7.2 1.3.2 1.8.1.5-.1 1.7-.7 1.9-1.4.2-.7.2-1.3.2-1.4-.1-.2-.3-.2-.7-.4zM12 2.2C6.6 2.2 2.2 6.6 2.2 12c0 1.7.4 3.3 1.2 4.7L2 22l5.5-1.4C8.9 21.4 10.4 21.8 12 21.8c5.4 0 9.8-4.4 9.8-9.8S17.4 2.2 12 2.2z"/></svg>
        Quero simular a minha taxa
      </a>
    </footer>
  </div>
</dialog>
</div>

<style>
  .taxas-dialog {
    border: 0;
    padding: 0;
    background: transparent;
    max-width: min(1100px, calc(100vw - 1.5rem));
    width: 100%;
    max-height: calc(100vh - 2rem);
  }
  .taxas-dialog::backdrop {
    background: rgba(10, 15, 13, 0.72);
    backdrop-filter: blur(4px);
  }
  .taxas-inner {
    background: #FAFAF7;
    border-radius: 20px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    max-height: calc(100vh - 2rem);
    box-shadow: 0 32px 80px -24px rgba(10, 15, 13, 0.5);
  }
  .taxas-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
    padding: 1.25rem 1.25rem 1rem;
    border-bottom: 1px solid #E4E7E4;
  }
  .taxas-eyebrow {
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #00A324;
  }
  .taxas-title {
    font-family: 'Space Grotesk', system-ui, sans-serif;
    font-size: 1.15rem;
    font-weight: 700;
    color: #0A0F0D;
    margin-top: 0.25rem;
    line-height: 1.2;
  }
  .taxas-close {
    flex-shrink: 0;
    width: 34px; height: 34px;
    border-radius: 9999px;
    border: 1px solid #E4E7E4;
    background: #fff;
    color: #3A4441;
    display: flex; align-items: center; justify-content: center;
    cursor: pointer;
    transition: background 150ms ease;
  }
  .taxas-close:hover { background: #EEF0EC; }

  .taxas-tabs {
    display: flex;
    gap: 0.5rem;
    padding: 0.85rem 1.25rem;
    border-bottom: 1px solid #E4E7E4;
    background: #F3F3EF;
  }
  .taxas-tab {
    border: 1px solid #E4E7E4;
    background: #fff;
    color: #3A4441;
    font-size: 13px;
    font-weight: 600;
    padding: 0.5rem 1rem;
    border-radius: 9999px;
    cursor: pointer;
    transition: all 160ms ease;
  }
  .taxas-tab:hover { border-color: #00CC2C; }
  .taxas-tab.is-active { background: #00CC2C; border-color: #00CC2C; color: #0A0F0D; }

  .taxas-body {
    overflow: auto;
    padding: 1rem 1.25rem;
    flex: 1;
    -webkit-overflow-scrolling: touch;
  }
  .taxas-panel { display: none; }
  .taxas-panel.is-active { display: block; }
  .taxas-panel-note {
    font-size: 13px;
    color: #6B7773;
    line-height: 1.6;
    margin: 0 0 0.85rem;
  }
  .taxas-panel-note strong { color: #0A0F0D; }

  .taxas-scroll {
    overflow-x: auto;
    border: 1px solid #E4E7E4;
    border-radius: 12px;
    background: #fff;
    -webkit-overflow-scrolling: touch;
  }
  .taxas-table {
    border-collapse: separate;
    border-spacing: 0;
    width: 100%;
    min-width: 560px;
    font-size: 13px;
  }
  .taxas-table th,
  .taxas-table td {
    padding: 0.55rem 0.75rem;
    text-align: right;
    white-space: nowrap;
    border-bottom: 1px solid #EEF0EC;
  }
  .taxas-table thead th {
    position: sticky;
    top: 0;
    z-index: 2;
    background: #0A0F0D;
    color: #fff;
    font-family: 'Space Grotesk', system-ui, sans-serif;
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    border-bottom: 0;
    vertical-align: bottom;
  }
  .taxas-table thead th.is-best { background: #00A324; }
  .best-badge {
    display: block;
    font-size: 8px;
    font-weight: 700;
    letter-spacing: 0.1em;
    color: #B9F5C6;
    margin-top: 2px;
  }
  .taxas-table .col-label {
    position: sticky;
    left: 0;
    z-index: 1;
    background: #F3F3EF;
    text-align: left;
    font-weight: 600;
    color: #0A0F0D;
    font-size: 12px;
    box-shadow: 1px 0 0 #E4E7E4;
  }
  .taxas-table thead .col-label {
    z-index: 3;
    background: #0A0F0D;
    color: #fff;
    box-shadow: 1px 0 0 rgba(255,255,255,0.12);
  }
  .taxas-table tbody td {
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    color: #3A4441;
    font-variant-numeric: tabular-nums;
  }
  .taxas-table tbody td.is-best {
    background: #E6F9EC;
    color: #0A0F0D;
    font-weight: 600;
  }
  .taxas-table tbody tr:hover td { background: #F7F8F6; }
  .taxas-table tbody tr:hover td.is-best { background: #D7F5E1; }
  .taxas-table tbody tr:last-child th,
  .taxas-table tbody tr:last-child td { border-bottom: 0; }

  .row-pix th, .row-pix td {
    background: #0A0F0D !important;
    color: #00E63A !important;
    font-weight: 700;
    box-shadow: none;
  }
  .row-pix th { color: #fff !important; }

  .taxas-footer {
    padding: 1rem 1.25rem 1.25rem;
    border-top: 1px solid #E4E7E4;
    background: #F3F3EF;
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
  }
  .taxas-footer p {
    font-size: 11px;
    color: #6B7773;
    line-height: 1.6;
    margin: 0;
  }
  @media (min-width: 640px) {
    .taxas-footer { flex-direction: row; align-items: center; justify-content: space-between; }
    .taxas-footer p { flex: 1; }
  }
</style>

<script is:inline>
(function () {
  document.querySelectorAll('[data-taxas-root]').forEach(function (root) {
    var btn = root.querySelector('[data-taxas-open]');
    var dialog = root.querySelector('[data-taxas-dialog]');
    if (!btn || !dialog) return;

    btn.addEventListener('click', function () {
      if (typeof dialog.showModal === 'function') dialog.showModal();
      else dialog.setAttribute('open', '');
      document.body.style.overflow = 'hidden';
    });

    dialog.querySelectorAll('[data-taxas-close]').forEach(function (close) {
      close.addEventListener('click', function () { dialog.close(); });
    });

    dialog.addEventListener('click', function (e) {
      if (e.target === dialog) dialog.close();
    });

    dialog.addEventListener('close', function () {
      document.body.style.overflow = '';
    });

    dialog.querySelectorAll('[data-taxas-tab]').forEach(function (tab) {
      tab.addEventListener('click', function () {
        var key = tab.getAttribute('data-taxas-tab');
        dialog.querySelectorAll('[data-taxas-tab]').forEach(function (t) {
          t.classList.toggle('is-active', t === tab);
        });
        dialog.querySelectorAll('[data-taxas-panel]').forEach(function (p) {
          p.classList.toggle('is-active', p.getAttribute('data-taxas-panel') === key);
        });
        var body = dialog.querySelector('.taxas-body');
        if (body) body.scrollTop = 0;
      });
    });
  });
})();
</script>
