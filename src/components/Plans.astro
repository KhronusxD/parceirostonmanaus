---
import TabelaTaxas from './TabelaTaxas.astro';

const wa = (msg: string) => 'https://wa.me/lojatonmanaus?text=' + encodeURIComponent(msg);

const plans = [
  {
    name: 'Ton Mega+',
    tag: 'Aceita CPF e CNPJ',
    desc: 'Pra quem tá começando ou vende em qualquer volume. Sem faturamento mínimo.',
    rates: [
      ['Débito', 'a partir de 2,48%'],
      ['Crédito à vista', 'a partir de 4,14%'],
      ['Pix', '0% ilimitado']
    ],
    note: 'Tem faixa promocional no começo, com débito a 2,57% e crédito à vista a 4,34%.',
    cta: 'Quero o Ton Mega+',
    href: wa('Olá! Vim pelo site e quero saber mais sobre o plano Ton Mega+.')
  },
  {
    name: 'Ton Black',
    tag: 'Exclusivo MEI e CNPJ',
    highlight: true,
    desc: 'Condição negociada pra quem fatura acima de R$ 20 mil por mês. Quanto mais você vende, menor a taxa.',
    rates: [
      ['Débito', 'a partir de 0,74%'],
      ['Crédito à vista', 'a partir de 2,68%'],
      ['Pix', '0% ilimitado']
    ],
    note: 'Faixas por faturamento: R$ 20 mil, R$ 40 mil, R$ 80 mil e acima. Recebimento em 1 dia útil.',
    cta: 'Ver o Plano Ton Black',
    href: '/ton-black',
    internal: true
  }
];
---
<section id="planos" class="relative py-24 md:py-32 bg-paper-soft">
  <div class="container-x">
    <div class="max-w-2xl mx-auto text-center">
      <span class="eyebrow">03 · Planos e taxas</span>
      <h2 class="mt-3 text-3xl md:text-5xl font-bold text-ink-950">
        Taxas que cabem no seu bolso.
      </h2>
      <p class="mt-4 text-ink-500 text-base md:text-lg">
        Escolha o plano que combina com o seu volume. Sem aluguel, sem mensalidade,
        sem letra miúda. E <strong class="text-ink-950">Pix sempre 0%, ilimitado</strong>.
      </p>
    </div>

    <div class="mt-14 grid grid-cols-1 md:grid-cols-2 gap-5 max-w-4xl mx-auto">
      {plans.map((p) => (
        <div class:list={[
          'card p-7 md:p-8 relative overflow-hidden transition-all duration-300 hover:-translate-y-0.5 hover:shadow-card flex flex-col',
          p.highlight ? 'ring-1 ring-ton/60 bg-paper-pure' : ''
        ]}>
          { p.highlight && (
            <div class="absolute top-0 left-0 right-0 h-1 bg-ton"></div>
          )}

          <div class="mb-5">
            <h3 class="font-display text-2xl md:text-3xl font-semibold text-ink-950">{p.name}</h3>
            <span class="text-xs text-ton-deep mt-1 inline-block font-medium">{p.tag}</span>
            <p class="mt-3 text-sm text-ink-500 leading-relaxed">{p.desc}</p>
          </div>

          <ul class="space-y-3 mb-5">
            {p.rates.map(([label, val]) => (
              <li class="flex items-baseline justify-between gap-4 border-b border-line pb-2">
                <span class="text-sm text-ink-500 shrink-0">{label}</span>
                <span class="font-mono text-sm md:text-base text-ink-950 font-semibold text-right">{val}</span>
              </li>
            ))}
          </ul>

          <p class="text-xs text-ink-500 leading-relaxed flex-1">{p.note}</p>

          <a
            href={p.href}
            target={p.internal ? undefined : '_blank'}
            rel={p.internal ? undefined : 'noopener'}
            class:list={['btn mt-6 w-full', p.highlight ? 'btn-wa' : 'btn-ghost']}
            data-cta={`plano-${p.name.toLowerCase().replace(/\s+/g,'-')}`}
          >
            {p.cta}
            <span aria-hidden="true">→</span>
          </a>
        </div>
      ))}
    </div>

    <div class="mt-10 flex flex-col items-center gap-4 text-center">
      <TabelaTaxas label="Ver tabela completa de taxas" />
      <p class="text-xs text-ink-500 max-w-xl">
        Taxas de referência. A condição final depende do plano contratado e do volume mensal.
        Fazemos uma simulação personalizada no atendimento.
      </p>
    </div>
  </div>
</section>
