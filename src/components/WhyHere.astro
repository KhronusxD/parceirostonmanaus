---
const reasons = [
  {
    icon: 'rocket',
    title: 'Retirada hoje.',
    text: 'Você pega a maquininha na loja e sai vendendo no mesmo dia. Sem depender de Correios.'
  },
  {
    icon: 'people',
    title: 'Consultor local.',
    text: 'Alguém de Manaus atende você — não um chatbot em São Paulo. A gente entende o comércio daqui.'
  },
  {
    icon: 'gear',
    title: 'Ativação assistida.',
    text: 'Configuramos a máquina com você, na hora. Você sai da loja já cobrando.'
  },
  {
    icon: 'shield',
    title: 'Suporte pós-venda.',
    text: 'Deu problema? A gente tá aqui. É só descer no Centro ou mandar no WhatsApp.'
  }
];
---
<section id="por-que" class="relative py-24 md:py-32">
  <div class="container-x">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16 items-start">
      <div class="lg:col-span-5 lg:sticky lg:top-24">
        <span class="eyebrow">01 · Diferencial</span>
        <h2 class="mt-3 text-3xl md:text-5xl font-bold text-ink-950">
          Comprar aqui é <span class="italic text-ton-deep">diferente</span> de comprar no site.
        </h2>
        <p class="mt-6 text-ink-500 text-base md:text-lg leading-relaxed">
          O aparelho é o mesmo — oficial da Ton. Mas a experiência muda tudo:
          você tem gente de verdade, aqui no Centro de Manaus, do primeiro contato ao pós-venda.
        </p>
      </div>

      <div class="lg:col-span-7 grid grid-cols-1 sm:grid-cols-2 gap-5">
        {reasons.map((r) => (
          <div class="card p-6 hover:-translate-y-0.5 hover:shadow-card transition-all group">
            <div class="h-11 w-11 rounded-full bg-ton-soft flex items-center justify-center text-ton-deep mb-5 group-hover:bg-ton group-hover:text-ink-950 transition-colors">
              { r.icon === 'rocket' && (
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09z"/><path d="M12 15l-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2z"/><path d="M9 12H4s.55-3.03 2-4c1.62-1.08 5 0 5 0"/></svg>
              )}
              { r.icon === 'people' && (
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
              )}
              { r.icon === 'gear' && (
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09a1.65 1.65 0 0 0-1-1.51 1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09a1.65 1.65 0 0 0 1.51-1 1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
              )}
              { r.icon === 'shield' && (
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
              )}
            </div>
            <h3 class="font-display text-xl font-semibold text-ink-950 mb-2">{r.title}</h3>
            <p class="text-sm text-ink-500 leading-relaxed">{r.text}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
