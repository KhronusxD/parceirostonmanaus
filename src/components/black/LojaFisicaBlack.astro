---
const wa = 'https://wa.me/5592981074692?text=' + encodeURIComponent(
  'Olá! Vi a localização no site e quero visitar a loja.'
);

const unidades = [
  {
    tag: 'Unidade Centro',
    endereco: 'Av. Eduardo Ribeiro, 520, Sala 02',
    complemento: 'Ed. Manaus Shopping Center',
    cep: 'Manaus/AM, CEP 69010-000',
    mapaEmbed: 'https://www.google.com/maps?q=Av.%20Eduardo%20Ribeiro%2C%20520%20-%20Centro%2C%20Manaus%20-%20AM&output=embed',
    mapaLink: 'https://maps.google.com/?q=Av.+Eduardo+Ribeiro+520+Manaus',
  },
  {
    tag: 'Unidade Cidade Nova',
    endereco: 'Rua Felix Valois, 41',
    complemento: 'Cidade Nova, perto da Blue Fit',
    cep: 'Manaus/AM',
    mapaEmbed: 'https://www.google.com/maps?q=Rua%20Felix%20Valois%2041%2C%20Cidade%20Nova%2C%20Manaus%20-%20AM&output=embed',
    mapaLink: 'https://maps.google.com/?q=Rua+Felix+Valois+41+Cidade+Nova+Manaus',
  }
];
---
<section class="relative py-24 md:py-32">
  <div class="container-x">
    <div class="max-w-3xl">
      <span class="eyebrow">Lojas físicas em Manaus</span>
      <h2 class="mt-3 text-3xl md:text-5xl font-bold text-ink-950 leading-[1.05]">
        Duas unidades em Manaus.
      </h2>
      <p class="mt-5 text-ink-500 text-base md:text-lg leading-relaxed">
        Se preferir tratar pessoalmente, temos loja no Centro e no Cidade Nova. Chegue, veja o aparelho,
        converse direto com o consultor e sai com sua condição Black já ativada. Segunda a sexta, 9h às 17h.
      </p>
    </div>

    <!-- 2 unidades com mapa próprio -->
    <div class="mt-12 grid grid-cols-1 md:grid-cols-2 gap-6">
      {unidades.map((u) => (
        <div class="card overflow-hidden flex flex-col">
          <div class="relative aspect-[4/3] bg-paper-soft">
            <iframe
              src={u.mapaEmbed}
              width="100%" height="100%" loading="lazy"
              style="border:0;"
              referrerpolicy="no-referrer-when-downgrade"
              title={`Mapa da ${u.tag}`}
            ></iframe>
          </div>
          <div class="p-6 md:p-7 flex-1 flex flex-col">
            <span class="eyebrow">{u.tag}</span>
            <div class="mt-3 text-ink-950 leading-snug">
              <strong class="font-semibold">{u.endereco}</strong><br/>
              <span class="text-ink-700">{u.complemento}</span><br/>
              <span class="text-ink-500 text-sm">{u.cep}</span>
            </div>
            <div class="mt-6 flex flex-wrap gap-2 pt-4 border-t border-line">
              <a href={wa} target="_blank" rel="noopener" class="btn btn-wa text-xs px-4 py-2.5" data-cta={`loja-black-${u.tag.toLowerCase().replace(/\s+/g,'-')}`}>WhatsApp</a>
              <a href={u.mapaLink} target="_blank" rel="noopener" class="btn btn-ghost text-xs px-4 py-2.5">Como chegar</a>
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- Galeria de fotos reais dos ambientes internos -->
    <div class="mt-8 grid grid-cols-3 gap-3 md:gap-4">
      <div class="aspect-[4/3] rounded-2xl border border-line overflow-hidden bg-paper-soft">
        <img src="/store-1.webp" alt="Ambiente interno da loja" loading="lazy" class="h-full w-full object-cover" />
      </div>
      <div class="aspect-[4/3] rounded-2xl border border-line overflow-hidden bg-paper-soft">
        <img src="/store-2.webp" alt="Ambiente interno da loja" loading="lazy" class="h-full w-full object-cover" />
      </div>
      <div class="aspect-[4/3] rounded-2xl border border-line overflow-hidden bg-paper-soft">
        <img src="/store-3.webp" alt="Ambiente interno da loja" loading="lazy" class="h-full w-full object-cover" />
      </div>
    </div>
  </div>
</section>
