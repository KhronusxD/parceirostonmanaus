---
const wa = 'https://wa.me/5592981074692?text=' + encodeURIComponent(
  'Olá! Vi a localização no site e quero visitar a loja.'
);
---
<section class="relative py-24 md:py-32">
  <div class="container-x">
    <div class="max-w-3xl">
      <span class="eyebrow">Loja física em Manaus</span>
      <h2 class="mt-3 text-3xl md:text-5xl font-bold text-ink-950 leading-[1.05]">
        Passe na nossa loja no Centro.
      </h2>
      <p class="mt-5 text-ink-500 text-base md:text-lg leading-relaxed">
        Se preferir tratar pessoalmente, estamos no Ed. Manaus Shopping Center. Chegue, veja o aparelho,
        conversa direto com o consultor e sai com sua condição Black já ativada.
      </p>
    </div>

    <!-- Galeria de fotos reais dos ambientes internos -->
    <div class="mt-12 grid grid-cols-1 md:grid-cols-3 gap-3 md:gap-4">
      <div class="aspect-[4/3] rounded-2xl border border-line overflow-hidden bg-paper-soft">
        <img src="/store-1.webp" alt="Ambiente interno da loja" loading="lazy" class="h-full w-full object-cover" />
      </div>
      <div class="aspect-[4/3] rounded-2xl border border-line overflow-hidden bg-paper-soft">
        <img src="/store-2.webp" alt="Ambiente interno da loja" loading="lazy" class="h-full w-full object-cover" />
      </div>
      <div class="aspect-[4/3] rounded-2xl border border-line overflow-hidden bg-paper-soft">
        <img src="/store-3.webp" alt="Ambiente interno da loja" loading="lazy" class="h-full w-full object-cover" />
      </div>
    </div>

    <!-- Mapa + endereço -->
    <div class="mt-10 grid grid-cols-1 lg:grid-cols-12 gap-6 items-stretch">
      <div class="lg:col-span-7 relative aspect-[4/3] lg:aspect-auto rounded-3xl overflow-hidden border border-line bg-paper-pure">
        <iframe
          src="https://www.google.com/maps?q=Av.%20Eduardo%20Ribeiro%2C%20520%20-%20Centro%2C%20Manaus%20-%20AM&output=embed"
          width="100%" height="100%" loading="lazy"
          style="border:0;"
          referrerpolicy="no-referrer-when-downgrade"
          title="Mapa da Loja Parceira Ton Manaus"
        ></iframe>
      </div>

      <div class="lg:col-span-5 card p-7 flex flex-col">
        <div class="text-xs uppercase tracking-widest text-ton-deep font-mono">Endereço</div>
        <div class="mt-3 text-ink-950 leading-snug">
          Av. Eduardo Ribeiro, 520, Sala 02<br/>
          Ed. Manaus Shopping Center, Centro<br/>
          Manaus/AM, CEP 69010-000
        </div>

        <div class="mt-6 pt-6 border-t border-line">
          <div class="text-xs uppercase tracking-widest text-ton-deep font-mono">Horário</div>
          <div class="mt-2 text-ink-950">Segunda a sexta, 9h às 17h</div>
        </div>

        <div class="mt-auto pt-8 flex flex-wrap gap-3">
          <a href={wa} target="_blank" rel="noopener" class="btn btn-wa flex-1" data-cta="loja-black-wa">Chamar no WhatsApp</a>
          <a href="https://maps.google.com/?q=Av.+Eduardo+Ribeiro+520+Manaus" target="_blank" rel="noopener" class="btn btn-ghost">Como chegar</a>
        </div>
      </div>
    </div>
  </div>
</section>
