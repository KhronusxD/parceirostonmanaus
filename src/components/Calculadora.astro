---
import TabelaTaxas from './TabelaTaxas.astro';
---
<section id="calculadora" class="relative py-24 md:py-32">
  <div class="container-x">
    <div class="max-w-2xl mx-auto text-center">
      <span class="eyebrow">04 · Faça a conta</span>
      <h2 class="mt-3 text-3xl md:text-5xl font-bold text-ink-950 leading-[1.05]">
        Quanto você paga de taxa por mês?
      </h2>
      <p class="mt-4 text-ink-500 text-base md:text-lg">
        Coloque o seu faturamento e ajuste quanto das suas vendas entra em cada forma de pagamento.
        A conta usa as taxas oficiais do Ton.
      </p>
    </div>

    <div class="mt-14 max-w-5xl mx-auto grid grid-cols-1 lg:grid-cols-12 gap-6" data-calc>
      <!-- Controles -->
      <div class="lg:col-span-5 card p-6 md:p-7">
        <label class="block">
          <span class="text-xs uppercase tracking-widest text-ink-500">Faturamento no cartão por mês</span>
          <div class="mt-2 relative">
            <span class="absolute left-4 top-1/2 -translate-y-1/2 text-ink-500 font-display font-semibold">R$</span>
            <input
              type="text"
              inputmode="numeric"
              value="15.000"
              data-calc-faturamento
              class="w-full rounded-xl bg-paper border border-line pl-12 pr-4 py-3.5 text-ink-950 font-display text-xl font-bold focus:border-ton focus:ring-2 focus:ring-ton/20 focus:outline-none transition"
            />
          </div>
        </label>

        <div class="mt-7 space-y-6">
          <div>
            <div class="flex items-baseline justify-between mb-2">
              <span class="text-sm text-ink-700 font-medium">Pix</span>
              <span class="font-mono text-sm text-ton-deep font-bold" data-calc-out="pix">15%</span>
            </div>
            <input type="range" min="0" max="100" value="15" step="5" data-calc-slider="pix" class="calc-range" />
            <p class="mt-1.5 text-[11px] text-ton-deep font-medium">Taxa 0%. Cada real aqui é lucro cheio.</p>
          </div>

          <div>
            <div class="flex items-baseline justify-between mb-2">
              <span class="text-sm text-ink-700 font-medium">Débito</span>
              <span class="font-mono text-sm text-ink-950 font-bold" data-calc-out="debito">25%</span>
            </div>
            <input type="range" min="0" max="100" value="25" step="5" data-calc-slider="debito" class="calc-range" />
          </div>

          <div>
            <div class="flex items-baseline justify-between mb-2">
              <span class="text-sm text-ink-700 font-medium">Crédito à vista</span>
              <span class="font-mono text-sm text-ink-950 font-bold" data-calc-out="credito">40%</span>
            </div>
            <input type="range" min="0" max="100" value="40" step="5" data-calc-slider="credito" class="calc-range" />
          </div>

          <div>
            <div class="flex items-baseline justify-between mb-2">
              <span class="text-sm text-ink-700 font-medium">Parcelado <span class="text-ink-500 font-normal">(média 3x)</span></span>
              <span class="font-mono text-sm text-ink-950 font-bold" data-calc-out="parcelado">20%</span>
            </div>
            <input type="range" min="0" max="100" value="20" step="5" data-calc-slider="parcelado" class="calc-range" />
          </div>
        </div>

        <p class="mt-6 text-[11px] text-ink-500 leading-relaxed" data-calc-soma></p>
      </div>

      <!-- Resultado -->
      <div class="lg:col-span-7 flex flex-col gap-4">
        <div class="card p-6 md:p-8 bg-ink-950 border-ink-950 text-paper">
          <div class="font-mono text-[10px] uppercase tracking-widest text-ton" data-calc-plano>No plano Ton Mega+</div>
          <div class="mt-4 grid grid-cols-2 gap-6">
            <div>
              <div class="text-xs text-ink-300">Você paga de taxa</div>
              <div class="mt-1 font-display text-3xl md:text-4xl font-bold text-paper leading-none" data-calc-taxa-mes>R$ 0</div>
              <div class="mt-1 text-[11px] text-ink-300">por mês</div>
            </div>
            <div>
              <div class="text-xs text-ink-300">No ano</div>
              <div class="mt-1 font-display text-3xl md:text-4xl font-bold text-paper leading-none" data-calc-taxa-ano>R$ 0</div>
              <div class="mt-1 text-[11px] text-ink-300">de custo com maquininha</div>
            </div>
          </div>
          <div class="mt-6 pt-5 border-t border-ink-700 flex items-baseline justify-between gap-4">
            <span class="text-sm text-ink-200/85">Taxa efetiva sobre o total</span>
            <span class="font-mono text-lg font-bold text-ton" data-calc-efetiva>0,00%</span>
          </div>
        </div>

        <!-- Card do Pix -->
        <div class="card p-6 md:p-7 border-ton/40 bg-ton-soft">
          <div class="flex items-start gap-4">
            <div class="shrink-0 h-11 w-11 rounded-full bg-ton flex items-center justify-center text-ink-950 font-display font-bold text-sm">0%</div>
            <div>
              <h3 class="font-display text-lg font-semibold text-ink-950">O Pix não cobra nada de você</h3>
              <p class="mt-1.5 text-sm text-ink-700 leading-relaxed" data-calc-pix-msg>
                Aumente o Pix no controle ao lado e veja a taxa cair.
              </p>
            </div>
          </div>
        </div>

        <!-- Card do Black: aparece quando faturamento >= 20 mil -->
        <div class="card p-6 md:p-7 ring-1 ring-ton/60 hidden" data-calc-black>
          <div class="eyebrow">Você tem direito ao Ton Black</div>
          <p class="mt-3 text-sm text-ink-700 leading-relaxed">
            Com esse faturamento você entra na condição exclusiva pra MEI e CNPJ.
            Com a mesma divisão de vendas, a sua taxa cairia para
            <strong class="text-ink-950 font-mono" data-calc-black-efetiva>0,00%</strong>.
          </p>
          <div class="mt-5 flex items-baseline gap-2">
            <span class="text-xs uppercase tracking-widest text-ton-deep font-mono">Economia</span>
            <span class="font-display text-2xl font-bold text-ink-950" data-calc-black-economia>R$ 0</span>
            <span class="text-sm text-ink-500">por mês</span>
          </div>
          <a href="/ton-black" class="btn btn-wa mt-5 w-full sm:w-auto" data-cta="calculadora-black">
            Conhecer o Plano Ton Black
            <span aria-hidden="true">→</span>
          </a>
        </div>
      </div>
    </div>

    <div class="mt-10 flex flex-col items-center gap-4 text-center">
      <TabelaTaxas label="Ver tabela completa de taxas" defaultTab="mega" />
      <p class="text-xs text-ink-500 max-w-2xl leading-relaxed">
        Simulação com base nas tabelas oficiais do Ton, recebimento em 1 dia útil. O parcelado usa a taxa de 3x
        como média. A condição real depende do plano contratado e do seu histórico. Fazemos a conta exata
        com o seu extrato, sem compromisso.
      </p>
    </div>
  </div>
</section>

<style>
  .calc-range {
    width: 100%;
    height: 6px;
    border-radius: 9999px;
    background: #E4E7E4;
    outline: none;
    -webkit-appearance: none;
    appearance: none;
    cursor: pointer;
  }
  .calc-range::-webkit-slider-thumb {
    -webkit-appearance: none;
    appearance: none;
    width: 20px;
    height: 20px;
    border-radius: 9999px;
    background: #00CC2C;
    border: 3px solid #fff;
    box-shadow: 0 2px 6px rgba(10, 15, 13, 0.2);
    cursor: pointer;
  }
  .calc-range::-moz-range-thumb {
    width: 20px;
    height: 20px;
    border-radius: 9999px;
    background: #00CC2C;
    border: 3px solid #fff;
    box-shadow: 0 2px 6px rgba(10, 15, 13, 0.2);
    cursor: pointer;
  }
</style>

<script is:inline>
(function () {
  var root = document.querySelector('[data-calc]');
  if (!root) return;

  // Tabelas oficiais do Ton (débito, crédito à vista, parcelado 3x)
  var MEGA = [
    { max: 3000,     deb: 2.98, cred: 5.15, parc: 12.68 },
    { max: 6000,     deb: 2.68, cred: 4.63, parc: 9.79 },
    { max: 10000,    deb: 2.61, cred: 4.54, parc: 9.20 },
    { max: 30000,    deb: 2.51, cred: 4.31, parc: 7.55 },
    { max: Infinity, deb: 2.48, cred: 4.14, parc: 7.50 }
  ];
  var BLACK = [
    { max: 20000,    deb: 1.36, cred: 3.14, parc: 6.11 },
    { max: 40000,    deb: 0.84, cred: 2.88, parc: 4.82 },
    { max: 80000,    deb: 0.78, cred: 2.78, parc: 4.64 },
    { max: Infinity, deb: 0.74, cred: 2.68, parc: 4.45 }
  ];

  function faixa(tabela, valor) {
    for (var i = 0; i < tabela.length; i++) {
      if (valor <= tabela[i].max) return tabela[i];
    }
    return tabela[tabela.length - 1];
  }

  var input = root.querySelector('[data-calc-faturamento]');
  var sliders = {
    pix: root.querySelector('[data-calc-slider="pix"]'),
    debito: root.querySelector('[data-calc-slider="debito"]'),
    credito: root.querySelector('[data-calc-slider="credito"]'),
    parcelado: root.querySelector('[data-calc-slider="parcelado"]')
  };
  var outs = {
    pix: root.querySelector('[data-calc-out="pix"]'),
    debito: root.querySelector('[data-calc-out="debito"]'),
    credito: root.querySelector('[data-calc-out="credito"]'),
    parcelado: root.querySelector('[data-calc-out="parcelado"]')
  };
  var elSoma = root.querySelector('[data-calc-soma]');
  var elTaxaMes = root.querySelector('[data-calc-taxa-mes]');
  var elTaxaAno = root.querySelector('[data-calc-taxa-ano]');
  var elEfetiva = root.querySelector('[data-calc-efetiva]');
  var elPlano = root.querySelector('[data-calc-plano]');
  var elPixMsg = root.querySelector('[data-calc-pix-msg]');
  var elBlack = root.querySelector('[data-calc-black]');
  var elBlackEfetiva = root.querySelector('[data-calc-black-efetiva]');
  var elBlackEconomia = root.querySelector('[data-calc-black-economia]');

  function brl(v) {
    return 'R$ ' + Math.round(v).toLocaleString('pt-BR');
  }
  function pct(v) {
    return v.toFixed(2).replace('.', ',') + '%';
  }
  function parseFaturamento() {
    var raw = (input.value || '').replace(/\D/g, '');
    return raw ? parseInt(raw, 10) : 0;
  }

  function calcular() {
    var fat = parseFaturamento();
    var mix = {
      pix: parseInt(sliders.pix.value, 10),
      debito: parseInt(sliders.debito.value, 10),
      credito: parseInt(sliders.credito.value, 10),
      parcelado: parseInt(sliders.parcelado.value, 10)
    };
    var soma = mix.pix + mix.debito + mix.credito + mix.parcelado;

    Object.keys(outs).forEach(function (k) { outs[k].textContent = mix[k] + '%'; });

    if (soma !== 100) {
      elSoma.textContent = 'Os percentuais somam ' + soma + '%. Ajuste pra fechar em 100% e a conta fica exata.';
      elSoma.style.color = soma > 100 ? '#B91C1C' : '#6B7773';
    } else {
      elSoma.textContent = 'Percentuais somam 100%.';
      elSoma.style.color = '#00A324';
    }

    // Normaliza pra sempre calcular sobre 100%
    var base = soma > 0 ? soma : 1;
    var vPix = fat * (mix.pix / base);
    var vDeb = fat * (mix.debito / base);
    var vCred = fat * (mix.credito / base);
    var vParc = fat * (mix.parcelado / base);

    var fMega = faixa(MEGA, fat);
    var custoMega = vDeb * fMega.deb / 100 + vCred * fMega.cred / 100 + vParc * fMega.parc / 100;
    var efetivaMega = fat > 0 ? (custoMega / fat) * 100 : 0;

    elTaxaMes.textContent = brl(custoMega);
    elTaxaAno.textContent = brl(custoMega * 12);
    elEfetiva.textContent = pct(efetivaMega);
    elPlano.textContent = 'No plano Ton Mega+';

    // Mensagem do Pix
    if (mix.pix >= 50) {
      elPixMsg.textContent = 'Com ' + mix.pix + '% no Pix você já está economizando bastante. Esse pedaço do faturamento não paga nada de taxa.';
    } else {
      var maisPix = Math.min(mix.pix + 20, 100);
      var vExtra = fat * (20 / base);
      var economiaExtra = vExtra * fMega.cred / 100;
      elPixMsg.textContent = 'Se você levar mais 20% das vendas pro Pix, deixa de pagar cerca de ' +
        brl(economiaExtra) + ' por mês em taxa.';
    }

    // Black
    if (fat >= 20000) {
      var fBlack = faixa(BLACK, fat);
      var custoBlack = vDeb * fBlack.deb / 100 + vCred * fBlack.cred / 100 + vParc * fBlack.parc / 100;
      var efetivaBlack = fat > 0 ? (custoBlack / fat) * 100 : 0;
      elBlackEfetiva.textContent = pct(efetivaBlack);
      elBlackEconomia.textContent = brl(custoMega - custoBlack);
      elBlack.classList.remove('hidden');
    } else {
      elBlack.classList.add('hidden');
    }
  }

  // Máscara de milhar no input
  input.addEventListener('input', function () {
    var raw = input.value.replace(/\D/g, '');
    input.value = raw ? parseInt(raw, 10).toLocaleString('pt-BR') : '';
    calcular();
  });

  Object.keys(sliders).forEach(function (k) {
    sliders[k].addEventListener('input', calcular);
  });

  calcular();
})();
</script>
