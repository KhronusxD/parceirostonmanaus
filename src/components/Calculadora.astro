---
import TabelaTaxas from './TabelaTaxas.astro';
---
<section id="calculadora" class="relative py-24 md:py-32">
  <div class="container-x">
    <div class="max-w-2xl mx-auto text-center">
      <span class="eyebrow">04 · Faça a conta</span>
      <h2 class="mt-3 text-3xl md:text-5xl font-bold text-ink-950 leading-[1.05]">
        Quanto você economiza trocando pra Ton?
      </h2>
      <p class="mt-4 text-ink-500 text-base md:text-lg">
        Coloque o seu faturamento e a taxa que você paga hoje. A conta usa as taxas oficiais do Ton.
      </p>
    </div>

    <div class="mt-14 max-w-5xl mx-auto grid grid-cols-1 lg:grid-cols-12 gap-6" data-calc>
      <!-- Controles -->
      <div class="lg:col-span-5 card p-6 md:p-7">
        <label class="block">
          <span class="text-xs uppercase tracking-widest text-ink-500">Quanto você vende no cartão por mês</span>
          <div class="mt-2 relative">
            <span class="absolute left-4 top-1/2 -translate-y-1/2 text-ink-500 font-display font-semibold">R$</span>
            <input
              type="text" inputmode="numeric" value="15.000"
              data-calc-faturamento
              class="w-full rounded-xl bg-paper border border-line pl-12 pr-4 py-3.5 text-ink-950 font-display text-xl font-bold focus:border-ton focus:ring-2 focus:ring-ton/20 focus:outline-none transition"
            />
          </div>
        </label>

        <label class="block mt-6">
          <span class="text-xs uppercase tracking-widest text-ink-500">Sua taxa de crédito à vista hoje</span>
          <div class="mt-2 relative">
            <input
              type="text" inputmode="decimal" value="4,50"
              data-calc-taxa-atual
              class="w-full rounded-xl bg-paper border border-line pl-4 pr-10 py-3.5 text-ink-950 font-display text-xl font-bold focus:border-ton focus:ring-2 focus:ring-ton/20 focus:outline-none transition"
            />
            <span class="absolute right-4 top-1/2 -translate-y-1/2 text-ink-500 font-display font-semibold">%</span>
          </div>
          <span class="mt-1.5 block text-[11px] text-ink-500">
            Está no extrato da sua maquininha atual. Não sabe? Deixe como está, é a média de mercado.
          </span>
        </label>

        <div class="mt-7">
          <span class="text-xs uppercase tracking-widest text-ink-500">Como você mais recebe</span>
          <div class="mt-3 grid grid-cols-3 gap-2" data-calc-perfis>
            <button type="button" class="calc-perfil" data-calc-perfil="debito">
              <span class="block font-semibold text-sm">Débito</span>
              <span class="block text-[10px] opacity-70 mt-0.5">na maioria</span>
            </button>
            <button type="button" class="calc-perfil is-active" data-calc-perfil="equilibrado">
              <span class="block font-semibold text-sm">Equilibrado</span>
              <span class="block text-[10px] opacity-70 mt-0.5">um pouco de tudo</span>
            </button>
            <button type="button" class="calc-perfil" data-calc-perfil="credito">
              <span class="block font-semibold text-sm">Crédito</span>
              <span class="block text-[10px] opacity-70 mt-0.5">e parcelado</span>
            </button>
          </div>
        </div>

        <div class="mt-7 rounded-xl border border-ton/30 bg-ton-soft p-4">
          <div class="flex items-baseline justify-between mb-2">
            <span class="text-sm text-ink-950 font-medium">Quanto vai no Pix</span>
            <span class="font-mono text-sm text-ton-deep font-bold" data-calc-out-pix>15%</span>
          </div>
          <input type="range" min="0" max="80" value="15" step="5" data-calc-pix class="calc-range" />
          <p class="mt-2 text-[11px] text-ink-700 leading-relaxed">
            No Ton o Pix é <strong>0%</strong>. Cada real que entra por aqui é lucro cheio.
            Basta cadastrar uma chave (CPF, CNPJ ou telefone).
          </p>
        </div>
      </div>

      <!-- Resultado -->
      <div class="lg:col-span-7 flex flex-col gap-4">
        <!-- Economia -->
        <div class="card p-6 md:p-8 bg-ink-950 border-ink-950 text-paper">
          <div class="font-mono text-[10px] uppercase tracking-widest text-ton">Sua economia trocando pra Ton</div>
          <div class="mt-4 flex items-end gap-3 flex-wrap">
            <div class="font-display text-4xl md:text-5xl font-bold text-ton leading-none" data-calc-economia-mes>R$ 0</div>
            <div class="text-sm text-ink-300 pb-1">por mês</div>
          </div>
          <div class="mt-3 text-base text-ink-200/85" data-calc-economia-ano>
            R$ 0 no ano
          </div>

          <div class="mt-6 pt-5 border-t border-ink-700 grid grid-cols-2 gap-5">
            <div>
              <div class="text-[11px] text-ink-300">Você paga hoje</div>
              <div class="mt-1 font-display text-xl font-bold text-ink-200 line-through" data-calc-custo-atual>R$ 0</div>
            </div>
            <div>
              <div class="text-[11px] text-ink-300">Pagaria na Ton</div>
              <div class="mt-1 font-display text-xl font-bold text-paper" data-calc-custo-ton>R$ 0</div>
            </div>
          </div>
        </div>

        <!-- Detalhe -->
        <div class="card p-6">
          <div class="flex items-baseline justify-between gap-4 pb-3 border-b border-line">
            <span class="text-sm text-ink-500">Sua taxa efetiva na Ton</span>
            <span class="font-mono text-lg font-bold text-ton-deep" data-calc-efetiva>0,00%</span>
          </div>
          <p class="mt-3 text-xs text-ink-500 leading-relaxed" data-calc-detalhe></p>
        </div>

        <!-- Card do Black -->
        <div class="card p-6 md:p-7 ring-1 ring-ton/60 hidden" data-calc-black>
          <div class="eyebrow">Você tem direito ao Ton Black</div>
          <p class="mt-3 text-sm text-ink-700 leading-relaxed">
            Com esse faturamento você entra na condição exclusiva pra MEI e CNPJ, e a economia sobe para
            <strong class="text-ink-950 font-display text-base" data-calc-black-economia>R$ 0</strong> por mês.
          </p>
          <a href="/ton-black" class="btn btn-wa mt-5 w-full sm:w-auto" data-cta="calculadora-black">
            Conhecer o Plano Ton Black
            <span aria-hidden="true">→</span>
          </a>
        </div>
      </div>
    </div>

    <div class="mt-10 flex flex-col items-center gap-4 text-center">
      <TabelaTaxas label="Ver tabela completa de taxas" defaultTab="mega" />
      <p class="text-xs text-ink-500 max-w-2xl leading-relaxed">
        Simulação com base nas tabelas oficiais do Ton, recebimento em 1 dia útil. O parcelado usa a taxa de 3x
        como média e assume que a sua taxa atual de débito e parcelado acompanha a de crédito na mesma proporção.
        A conta exata sai do seu extrato, na análise gratuita.
      </p>
    </div>
  </div>
</section>

<style>
  .calc-range {
    width: 100%; height: 6px; border-radius: 9999px;
    background: #D7F5E1; outline: none;
    -webkit-appearance: none; appearance: none; cursor: pointer;
  }
  .calc-range::-webkit-slider-thumb {
    -webkit-appearance: none; appearance: none;
    width: 20px; height: 20px; border-radius: 9999px;
    background: #00CC2C; border: 3px solid #fff;
    box-shadow: 0 2px 6px rgba(10, 15, 13, 0.2); cursor: pointer;
  }
  .calc-range::-moz-range-thumb {
    width: 20px; height: 20px; border-radius: 9999px;
    background: #00CC2C; border: 3px solid #fff;
    box-shadow: 0 2px 6px rgba(10, 15, 13, 0.2); cursor: pointer;
  }
  .calc-perfil {
    border: 1px solid #E4E7E4;
    background: #fff;
    color: #3A4441;
    border-radius: 12px;
    padding: 0.7rem 0.4rem;
    cursor: pointer;
    transition: all 160ms ease;
    text-align: center;
  }
  .calc-perfil:hover { border-color: #00CC2C; }
  .calc-perfil.is-active {
    background: #0A0F0D;
    border-color: #0A0F0D;
    color: #fff;
  }
</style>

<script is:inline>
(function () {
  var root = document.querySelector('[data-calc]');
  if (!root) return;

  var MEGA = [
    { max: 3000,     deb: 2.98, cred: 5.15, parc: 12.68 },
    { max: 6000,     deb: 2.68, cred: 4.63, parc: 9.79 },
    { max: 10000,    deb: 2.61, cred: 4.54, parc: 9.20 },
    { max: 30000,    deb: 2.51, cred: 4.31, parc: 7.55 },
    { max: Infinity, deb: 2.48, cred: 4.14, parc: 7.50 }
  ];
  var BLACK = [
    { max: 20000,    deb: 1.36, cred: 3.14, parc: 6.11 },
    { max: 40000,    deb: 0.84, cred: 2.88, parc: 4.82 },
    { max: 80000,    deb: 0.78, cred: 2.78, parc: 4.64 },
    { max: Infinity, deb: 0.74, cred: 2.68, parc: 4.45 }
  ];

  // Perfis: proporção entre débito, crédito à vista e parcelado (o Pix sai do slider)
  var PERFIS = {
    debito:      { deb: 0.62, cred: 0.26, parc: 0.12 },
    equilibrado: { deb: 0.30, cred: 0.47, parc: 0.23 },
    credito:     { deb: 0.16, cred: 0.48, parc: 0.36 }
  };

  function faixa(tabela, valor) {
    for (var i = 0; i < tabela.length; i++) {
      if (valor <= tabela[i].max) return tabela[i];
    }
    return tabela[tabela.length - 1];
  }
  function brl(v) { return 'R$ ' + Math.round(v).toLocaleString('pt-BR'); }
  function pct(v) { return v.toFixed(2).replace('.', ',') + '%'; }

  var input = root.querySelector('[data-calc-faturamento]');
  var inputTaxa = root.querySelector('[data-calc-taxa-atual]');
  var sliderPix = root.querySelector('[data-calc-pix]');
  var outPix = root.querySelector('[data-calc-out-pix]');
  var botoes = root.querySelectorAll('[data-calc-perfil]');

  var elEconomiaMes = root.querySelector('[data-calc-economia-mes]');
  var elEconomiaAno = root.querySelector('[data-calc-economia-ano]');
  var elCustoAtual = root.querySelector('[data-calc-custo-atual]');
  var elCustoTon = root.querySelector('[data-calc-custo-ton]');
  var elEfetiva = root.querySelector('[data-calc-efetiva]');
  var elDetalhe = root.querySelector('[data-calc-detalhe]');
  var elBlack = root.querySelector('[data-calc-black]');
  var elBlackEconomia = root.querySelector('[data-calc-black-economia]');

  var perfilAtivo = 'equilibrado';

  function parseNum(el) {
    var raw = (el.value || '').replace(/\D/g, '');
    return raw ? parseInt(raw, 10) : 0;
  }
  function parseTaxa() {
    var raw = (inputTaxa.value || '').replace(',', '.').replace(/[^\d.]/g, '');
    var v = parseFloat(raw);
    return isNaN(v) ? 0 : v;
  }

  function custo(fat, mix, tabela) {
    return fat * mix.pix * 0
         + fat * mix.deb * tabela.deb / 100
         + fat * mix.cred * tabela.cred / 100
         + fat * mix.parc * tabela.parc / 100;
  }

  function calcular() {
    var fat = parseNum(input);
    var taxaAtualCred = parseTaxa();
    var pctPix = parseInt(sliderPix.value, 10);
    outPix.textContent = pctPix + '%';

    // Distribui o que não é Pix conforme o perfil
    var resto = (100 - pctPix) / 100;
    var p = PERFIS[perfilAtivo];
    var mix = {
      pix: pctPix / 100,
      deb: resto * p.deb,
      cred: resto * p.cred,
      parc: resto * p.parc
    };

    // Concorrente: usa a taxa informada no crédito e projeta débito/parcelado
    // na mesma proporção que a Ton pratica, pra ser uma comparação justa.
    var fMega = faixa(MEGA, fat);
    var fator = fMega.cred > 0 ? taxaAtualCred / fMega.cred : 1;
    var atual = {
      deb: fMega.deb * fator,
      cred: taxaAtualCred,
      parc: fMega.parc * fator
    };

    // No concorrente o Pix costuma ter taxa; assumimos que ele cobra o mesmo do débito.
    var custoAtual = fat * mix.pix * atual.deb / 100
                   + fat * mix.deb * atual.deb / 100
                   + fat * mix.cred * atual.cred / 100
                   + fat * mix.parc * atual.parc / 100;

    var custoTon = custo(fat, mix, fMega);
    var economia = custoAtual - custoTon;
    var efetiva = fat > 0 ? (custoTon / fat) * 100 : 0;

    elCustoAtual.textContent = brl(custoAtual);
    elCustoTon.textContent = brl(custoTon);
    elEfetiva.textContent = pct(efetiva);

    if (economia > 0) {
      elEconomiaMes.textContent = brl(economia);
      elEconomiaMes.style.color = '';
      elEconomiaAno.textContent = brl(economia * 12) + ' no ano';
    } else {
      elEconomiaMes.textContent = brl(0);
      elEconomiaAno.textContent = 'Sua taxa atual já é competitiva. Mesmo assim, o Pix 0% e o suporte local continuam valendo.';
    }

    var economiaPix = fat * mix.pix * atual.deb / 100;
    elDetalhe.textContent = pctPix > 0
      ? 'Só no Pix você deixa de pagar ' + brl(economiaPix) + ' por mês, porque na Ton ele é 0%.'
      : 'Mova parte das vendas pro Pix no controle ao lado e veja a economia subir. Na Ton o Pix é 0%.';

    // Black
    if (fat >= 20000) {
      var fBlack = faixa(BLACK, fat);
      var custoBlack = custo(fat, mix, fBlack);
      elBlackEconomia.textContent = brl(custoAtual - custoBlack);
      elBlack.classList.remove('hidden');
    } else {
      elBlack.classList.add('hidden');
    }
  }

  input.addEventListener('input', function () {
    var raw = input.value.replace(/\D/g, '');
    input.value = raw ? parseInt(raw, 10).toLocaleString('pt-BR') : '';
    calcular();
  });
  inputTaxa.addEventListener('input', calcular);
  sliderPix.addEventListener('input', calcular);

  botoes.forEach(function (b) {
    b.addEventListener('click', function () {
      perfilAtivo = b.getAttribute('data-calc-perfil');
      botoes.forEach(function (o) { o.classList.toggle('is-active', o === b); });
      calcular();
    });
  });

  calcular();
})();
</script>
