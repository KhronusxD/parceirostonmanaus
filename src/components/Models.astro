---
const models = [
  {
    tag: 'Comece por aqui',
    name: 'TapTon',
    subtitle: 'Aceita cartão no seu Android',
    price: 'Grátis',
    img: '/ai-tapton.webp',
    desc: 'Sem hardware. O próprio celular vira maquininha por aproximação. Ideal pra autônomo e MEI iniciante.',
    for: 'Autônomo · MEI iniciante'
  },
  {
    name: 'T1',
    subtitle: 'Bluetooth com o celular',
    price: '17',
    img: '/ai-t1.webp',
    desc: 'A menor e mais leve da linha. Conecta no celular por Bluetooth. Perfeita pra quem vende em movimento.',
    for: 'Delivery · Feira · Uber'
  },
  {
    name: 'T2',
    subtitle: 'Autônoma com 3G e Wi-Fi',
    price: '40',
    img: '/ai-t2.webp',
    desc: 'Não depende do celular. Chip próprio e Wi-Fi. Comprovante por SMS ou e-mail.',
    for: 'Consultório · Serviço em campo'
  },
  {
    tag: 'Mais vendida',
    highlight: true,
    name: 'T3',
    subtitle: '3G, Wi-Fi, impressora e teclado',
    price: '86',
    img: '/ai-t3.webp',
    desc: 'Tudo da T2, com impressora térmica pra comprovante físico e teclado pra digitar valor rápido. Balcão em geral.',
    for: 'Loja · Restaurante · Balcão'
  },
  {
    tag: 'Top de linha',
    name: 'T3 Smart',
    subtitle: 'Android embarcado e tela grande',
    price: '154',
    img: '/ai-t3-smart.webp',
    desc: 'O melhor da linha. Android embarcado, tela ampla, impressora. Interface fluida pra operar rápido.',
    for: 'Loja premium · Fluxo alto'
  }
];

const bannerWa = 'https://wa.me/lojatonmanaus?text=' + encodeURIComponent(
  'Olá! Vim do site e queria uma ajuda pra escolher a maquininha certa pro meu negócio.'
);
---
<section id="modelos" class="relative py-24 md:py-32">
  <div class="container-x">
    <div class="max-w-2xl">
      <span class="eyebrow">02 · Catálogo</span>
      <h2 class="mt-3 text-3xl md:text-5xl font-bold text-ink-950">
        Escolha a maquininha certa pro seu negócio.
      </h2>
      <p class="mt-4 text-ink-500 text-base md:text-lg">
        Todos os modelos oficiais do Ton, com <strong class="text-ink-950">pronta entrega em toda Manaus</strong>.
        Retire na loja no Centro ou receba no seu comércio ou residência. A gente sugere o modelo certo no atendimento.
      </p>
    </div>

    <!-- Mobile: carrossel horizontal com snap; Desktop: grid 2/3 colunas -->
    <div class="mt-14 flex md:grid overflow-x-auto md:overflow-visible snap-x snap-mandatory md:snap-none md:grid-cols-2 lg:grid-cols-3 gap-4 md:gap-5 -mx-5 px-5 md:mx-0 md:px-0 pb-4 md:pb-0 scrollbar-hide">
      {models.map((m) => {
        const wa = 'https://wa.me/lojatonmanaus?text=' + encodeURIComponent(
          `Olá! Vim pelo site e quero a maquininha ${m.name}.`
        );
        return (
        <article class:list={[
          'card p-6 md:p-7 flex flex-col relative overflow-hidden group transition-all duration-300 hover:-translate-y-0.5 hover:shadow-card',
          'shrink-0 w-[85%] snap-start md:w-auto md:shrink',
          m.highlight ? 'ring-1 ring-ton/40' : ''
        ]}>
          { m.tag && (
            <span class:list={[
              'absolute top-4 right-4 chip text-[10px] uppercase tracking-wider',
              m.highlight ? 'border-ton/40 bg-ton-soft text-ton-deep' : ''
            ]}>{m.tag}</span>
          ) }

          <div class="aspect-square w-full rounded-xl bg-paper-soft mb-6 flex items-center justify-center overflow-hidden">
            <img src={m.img} alt={`Maquininha Ton ${m.name}`} class="max-h-full max-w-full object-contain" loading="lazy" />
          </div>

          <div>
            <h3 class="text-2xl font-semibold text-ink-950">{m.name}</h3>
            <p class="text-sm text-ton-deep mt-0.5">{m.subtitle}</p>
          </div>

          <p class="mt-4 text-sm text-ink-500 leading-relaxed flex-1">{m.desc}</p>

          <div class="mt-6 pt-6 border-t border-line flex items-end justify-between">
            <div>
              <div class="text-xs text-ink-500">a partir de</div>
              <div class="font-display text-3xl font-bold text-ink-950">
                {m.price === 'Grátis' ? m.price : (<><span>R$ </span><span>{m.price}</span></>)}
              </div>
            </div>
            <div class="text-right">
              <div class="text-[10px] uppercase tracking-widest text-ink-500">pra</div>
              <div class="text-xs text-ink-700 mt-0.5 max-w-[130px]">{m.for}</div>
            </div>
          </div>

          <a href={wa} target="_blank" rel="noopener" class="btn btn-wa mt-5 w-full" data-cta={`modelo-${m.name.toLowerCase().replace(/\s+/g,'-')}-wa`}>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.5 14.4c-.3-.1-1.7-.8-2-.9-.3-.1-.5-.2-.7.2-.2.3-.8.9-.9 1.1-.2.2-.3.2-.6.1s-1.2-.4-2.3-1.4c-.8-.7-1.4-1.6-1.5-1.9-.2-.3 0-.5.1-.6.1-.1.3-.3.4-.5.1-.2.2-.3.3-.5.1-.2 0-.4 0-.5 0-.1-.7-1.6-.9-2.2-.2-.6-.5-.5-.7-.5h-.6c-.2 0-.5.1-.8.4s-1 1-1 2.5.9 2.9 1.1 3.1c.1.2 2 3.1 4.9 4.3.7.3 1.2.5 1.6.6.7.2 1.3.2 1.8.1.5-.1 1.7-.7 1.9-1.4.2-.7.2-1.3.2-1.4-.1-.2-.3-.2-.7-.4zM12 2.2C6.6 2.2 2.2 6.6 2.2 12c0 1.7.4 3.3 1.2 4.7L2 22l5.5-1.4C8.9 21.4 10.4 21.8 12 21.8c5.4 0 9.8-4.4 9.8-9.8S17.4 2.2 12 2.2z"/></svg>
            Quero a {m.name}
          </a>
        </article>
      )})}

      <!-- Banner de venda no 6º slot: card dark com foto do consultor + CTA de ajuda -->
      <article class="relative rounded-2xl overflow-hidden bg-ink-950 text-paper shrink-0 w-[85%] snap-start md:w-auto md:shrink flex flex-col group">
        <div class="relative flex-1 min-h-[280px] md:min-h-[320px]">
          <img
            src="/maquineta-joca.webp"
            alt="Consultor da loja com uma maquininha Ton"
            class="absolute inset-0 h-full w-full object-cover"
            loading="lazy"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-ink-950 via-ink-950/40 to-transparent"></div>
        </div>

        <div class="relative p-6 md:p-7 pt-4 md:pt-4">
          <span class="chip border-ton/40 bg-ton/15 text-ton text-[10px] uppercase tracking-widest">
            <span class="h-1.5 w-1.5 rounded-full bg-ton animate-pulse"></span>
            Ajuda ao vivo
          </span>
          <h3 class="mt-4 font-display text-2xl md:text-2xl font-semibold text-paper leading-tight">
            Não sabe qual escolher?
          </h3>
          <p class="mt-3 text-sm text-ink-200/85 leading-relaxed">
            Fale com um consultor de verdade. A gente sugere a maquininha certa
            pro seu negócio em 2 minutos.
          </p>
          <a href={bannerWa} target="_blank" rel="noopener" class="btn btn-wa mt-5 w-full" data-cta="banner-ajuda-wa">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.5 14.4c-.3-.1-1.7-.8-2-.9-.3-.1-.5-.2-.7.2-.2.3-.8.9-.9 1.1-.2.2-.3.2-.6.1s-1.2-.4-2.3-1.4c-.8-.7-1.4-1.6-1.5-1.9-.2-.3 0-.5.1-.6.1-.1.3-.3.4-.5.1-.2.2-.3.3-.5.1-.2 0-.4 0-.5 0-.1-.7-1.6-.9-2.2-.2-.6-.5-.5-.7-.5h-.6c-.2 0-.5.1-.8.4s-1 1-1 2.5.9 2.9 1.1 3.1c.1.2 2 3.1 4.9 4.3.7.3 1.2.5 1.6.6.7.2 1.3.2 1.8.1.5-.1 1.7-.7 1.9-1.4.2-.7.2-1.3.2-1.4-.1-.2-.3-.2-.7-.4zM12 2.2C6.6 2.2 2.2 6.6 2.2 12c0 1.7.4 3.3 1.2 4.7L2 22l5.5-1.4C8.9 21.4 10.4 21.8 12 21.8c5.4 0 9.8-4.4 9.8-9.8S17.4 2.2 12 2.2z"/></svg>
            Fale com a gente
          </a>
        </div>
      </article>
    </div>

    <p class="mt-8 text-xs text-ink-500 max-w-3xl">
      Valores de adesão referenciais. Podem variar conforme promoções vigentes do Ton e do plano contratado.
      Todas as maquininhas têm zero mensalidade, zero aluguel e garantia vitalícia do fabricante.
    </p>
  </div>
</section>
