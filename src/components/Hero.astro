---
const wa = 'https://wa.me/lojatonmanaus?text=' + encodeURIComponent('Olá! Vim pelo site e quero uma simulação de maquininha Ton.');
---
<section class="hero-scroll relative" data-hero-video>
  <div class="hero-pin sticky top-0 h-screen w-full overflow-hidden">

    <!-- VÍDEO em background: proporção natural, meio ancorado em 75% da viewport (centro do quadrante direito) -->
    <video
      class="hero-video absolute top-0 h-full w-auto max-w-none"
      style="left: 75%; transform: translateX(-50%);"
      src="https://pub-61b5d969a4e24870b3632f3f16c5a801.r2.dev/video-animation.mp4"
      crossorigin="anonymous"
      poster="/hero-poster.webp"
      muted
      playsinline
      preload="auto"
      aria-hidden="true"
    ></video>

    <!-- OVERLAY: gradiente branco esquerda → transparente. Esconde as bordas do vídeo à esquerda e cria fundo pro texto -->
    <div class="hero-overlay absolute inset-0 pointer-events-none" aria-hidden="true"></div>

    <!-- Indicador discreto de carregamento do vídeo (some quando canplaythrough) -->
    <div class="hero-video-loader absolute top-24 right-6 z-40 flex items-center gap-2 rounded-full bg-paper-pure/85 backdrop-blur border border-line px-3 py-1.5 text-[10px] font-mono uppercase tracking-wider text-ink-500 opacity-0 transition-opacity duration-300 pointer-events-none" aria-hidden="true">
      <span class="h-1.5 w-1.5 rounded-full bg-ton animate-pulse"></span>
      Carregando vídeo
    </div>

    <!-- CONTEÚDO: texto do hero à esquerda -->
    <div class="relative h-full container-x flex items-center">
      <div class="max-w-2xl lg:max-w-xl xl:max-w-2xl">
        <span class="chip bg-paper-pure" data-store-chip>
          <span class="h-1.5 w-1.5 rounded-full bg-ton animate-pulse" data-store-dot></span>
          <span data-store-status>Loja no Centro de Manaus</span>
          <span class="text-ink-500">· Seg a sex, 9h às 17h</span>
        </span>

        <h1 class="hero-headline mt-6 text-center lg:text-left text-4xl md:text-6xl lg:text-7xl font-bold leading-[1.02] tracking-tight text-ink-950">
          Sua maquininha Ton em Manaus,
          <span class="italic font-normal text-ton-deep"> na sua mão hoje.</span>
        </h1>

        <p class="mt-6 max-w-xl text-center lg:text-left mx-auto lg:mx-0 text-base md:text-lg lg:text-xl text-ink-700 leading-relaxed">
          T1, T2, T3 e T3 Smart em <strong class="text-ink-950">pronta entrega</strong>.
          Retire na loja no Centro ou <strong class="text-ink-950">receba onde estiver</strong>, em qualquer bairro de Manaus. Sem esperar Correios.
        </p>

        <div class="mt-8 flex flex-col sm:flex-row justify-center lg:justify-start gap-3">
          <a href={wa} target="_blank" rel="noopener" class="btn btn-wa" data-cta="hero-wa">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.5 14.4c-.3-.1-1.7-.8-2-.9-.3-.1-.5-.2-.7.2-.2.3-.8.9-.9 1.1-.2.2-.3.2-.6.1s-1.2-.4-2.3-1.4c-.8-.7-1.4-1.6-1.5-1.9-.2-.3 0-.5.1-.6.1-.1.3-.3.4-.5.1-.2.2-.3.3-.5.1-.2 0-.4 0-.5 0-.1-.7-1.6-.9-2.2-.2-.6-.5-.5-.7-.5h-.6c-.2 0-.5.1-.8.4s-1 1-1 2.5.9 2.9 1.1 3.1c.1.2 2 3.1 4.9 4.3.7.3 1.2.5 1.6.6.7.2 1.3.2 1.8.1.5-.1 1.7-.7 1.9-1.4.2-.7.2-1.3.2-1.4-.1-.2-.3-.2-.7-.4zM12 2.2C6.6 2.2 2.2 6.6 2.2 12c0 1.7.4 3.3 1.2 4.7L2 22l5.5-1.4C8.9 21.4 10.4 21.8 12 21.8c5.4 0 9.8-4.4 9.8-9.8S17.4 2.2 12 2.2z"/></svg>
            Falar no WhatsApp agora
          </a>
          <a href="#lead" class="btn btn-ghost bg-paper-pure/70 backdrop-blur">
            Quero uma simulação
            <span aria-hidden="true">→</span>
          </a>
        </div>

        <div class="mt-8 flex flex-wrap items-center justify-center lg:justify-start gap-x-6 gap-y-2 text-xs text-ink-700">
          <span class="flex items-center gap-1.5"><span class="h-1 w-1 rounded-full bg-ton"></span>Atendimento humano</span>
          <span class="flex items-center gap-1.5"><span class="h-1 w-1 rounded-full bg-ton"></span>Entrega em toda Manaus</span>
          <span class="flex items-center gap-1.5"><span class="h-1 w-1 rounded-full bg-ton"></span>Loja física no Centro</span>
          <span class="flex items-center gap-1.5"><span class="h-1 w-1 rounded-full bg-ton"></span>Sem mensalidade</span>
        </div>
      </div>
    </div>

    <!-- selo flutuante bottom-right (visível sobre o vídeo em desktop) -->
    <div class="absolute bottom-8 right-8 card px-4 py-3 max-w-[220px] hidden lg:block">
      <div class="flex items-center gap-3">
        <div class="h-9 w-9 rounded-full bg-ton-soft flex items-center justify-center text-ton-deep">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 13l4 4L19 7"/></svg>
        </div>
        <div class="text-xs">
          <div class="font-semibold text-ink-950">Pronta entrega</div>
          <div class="text-ink-500">retira hoje no Centro</div>
        </div>
      </div>
    </div>
  </div>

  <!-- Área extra de scroll: começa com altura 0 (hero se comporta como seção normal de 100vh
       enquanto o vídeo ainda tá carregando). O JS expande pra 180vh/220vh só depois que o vídeo
       está totalmente bufferizado — assim a primeira visita nunca "trava" o scroll. -->
  <div class="hero-scrub-space" style="height: 0" aria-hidden="true"></div>
</section>

<style>
  /* Vídeo: enhance visual — realce sutil pra disfarçar artefatos de compressão sem borrar */
  .hero-video {
    image-rendering: high-quality;
    -webkit-backface-visibility: hidden;
    backface-visibility: hidden;
    transform-style: preserve-3d;
    will-change: transform;
    filter: contrast(1.04) saturate(1.06);
  }

  /* Desktop: branco 100% opaco até bem passado do meio (esconde a borda esquerda do vídeo em ~35-40%), transição suave até transparente */
  .hero-overlay {
    background: linear-gradient(
      to right,
      #FAFAF7 0%,
      #FAFAF7 52%,
      rgba(250, 250, 247, 0.97) 60%,
      rgba(250, 250, 247, 0.75) 68%,
      rgba(250, 250, 247, 0.35) 78%,
      rgba(250, 250, 247, 0) 88%
    );
  }
  /* Mobile: vídeo full-viewport, gradiente misto pra headline ter contraste em qualquer frame */
  @media (max-width: 1023px) {
    .hero-video {
      left: 50% !important;
      transform: translateX(-50%) !important;
      object-position: center 30%;
    }
    .hero-overlay {
      background:
        /* Camada de escurecimento sutil no topo (pra headline preta ler sobre fundo claro do vídeo) */
        linear-gradient(
          to bottom,
          rgba(250, 250, 247, 0.55) 0%,
          rgba(250, 250, 247, 0.5) 25%,
          rgba(250, 250, 247, 0.75) 45%,
          #FAFAF7 62%,
          #FAFAF7 100%
        );
    }
  }
  /* Contorno branco sutil na headline pra não sumir com o vídeo em nenhum frame */
  .hero-headline {
    text-shadow:
      0 0 12px rgba(250, 250, 247, 0.85),
      0 1px 2px rgba(250, 250, 247, 0.9);
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  const section = document.querySelector('[data-hero-video]');
  if (section) {
    const video = section.querySelector('.hero-video') as HTMLVideoElement | null;
    if (video) {
      video.addEventListener('error', () => { video.style.display = 'none'; });

      const loader = section.querySelector('.hero-video-loader') as HTMLElement | null;
      const showLoader = () => { if (loader) loader.style.opacity = '1'; };
      const hideLoader = () => { if (loader) loader.style.opacity = '0'; };
      // Mostra o loader se ainda não tem dados suficientes após 400ms
      const loaderTimer = window.setTimeout(() => {
        if (video.readyState < 4) showLoader();
      }, 400);

      const scrubSpace = section.querySelector('.hero-scrub-space') as HTMLElement | null;

      const startAnimation = () => {
        window.clearTimeout(loaderTimer);
        hideLoader();
        video.pause();
        const dur = video.duration;
        if (!isFinite(dur) || dur <= 0) return;

        // Só agora expande a área de scroll — antes disso o hero é 100vh normal,
        // então o usuário não fica "preso" com um vídeo que ainda não responde.
        if (scrubSpace) {
          scrubSpace.style.height = window.innerWidth >= 1024 ? '220vh' : '180vh';
        }

        // Aguarda o layout aplicar antes de criar o ScrollTrigger, pra o cálculo start/end pegar a nova altura.
        requestAnimationFrame(() => {
          const anim = { t: 0 };
          gsap.to(anim, {
            t: dur,
            ease: 'none',
            scrollTrigger: {
              trigger: section,
              start: 'top top',
              end: 'bottom bottom',
              scrub: 0.6,
              invalidateOnRefresh: true
            },
            onUpdate: () => {
              if (Math.abs(video.currentTime - anim.t) > 0.02) {
                video.currentTime = anim.t;
              }
            }
          });
          ScrollTrigger.refresh();
        });
      };

      // Aguarda o vídeo estar TOTALMENTE bufferizado antes de habilitar o scrub —
      // evita travadas nas primeiras rolagens enquanto os frames ainda estão chegando.
      const isFullyBuffered = () => {
        if (video.readyState >= 4) return true;
        if (video.buffered.length && isFinite(video.duration)) {
          return video.buffered.end(video.buffered.length - 1) >= video.duration - 0.25;
        }
        return false;
      };

      const armWhenReady = () => {
        if (isFullyBuffered()) { startAnimation(); return; }
        video.addEventListener('canplaythrough', startAnimation, { once: true });
        // fallback: se em 15s ainda não bufferizou tudo, engata assim mesmo
        const fallback = window.setTimeout(() => {
          video.removeEventListener('canplaythrough', startAnimation);
          startAnimation();
        }, 15000);
        video.addEventListener('canplaythrough', () => window.clearTimeout(fallback), { once: true });
      };

      if (video.readyState >= 1) armWhenReady();
      else video.addEventListener('loadedmetadata', armWhenReady, { once: true });
    }
  }
</script>
