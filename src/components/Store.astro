---
const wa = 'https://wa.me/lojatonmanaus?text=' + encodeURIComponent('Olá! Vi a localização no site e quero conversar.');
---
<section id="loja" class="relative py-24 md:py-32 bg-paper-soft">
  <div class="container-x">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 items-center">
      <div class="lg:col-span-5">
        <span class="eyebrow">04 · Loja física</span>
        <h2 class="mt-3 text-3xl md:text-5xl font-bold text-ink-950">
          Estamos no coração do Centro.
        </h2>
        <p class="mt-5 text-ink-500 text-base md:text-lg leading-relaxed">
          Chegue, veja o aparelho, sinta na mão e leve pra casa já ativado.
          Estacionamento no próprio edifício e várias linhas de ônibus na porta.
        </p>

        <dl class="mt-8 space-y-4">
          <div class="flex gap-4">
            <div class="mt-0.5 h-9 w-9 rounded-full bg-paper-pure border border-line flex items-center justify-center text-ton-deep shrink-0">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            </div>
            <div>
              <dt class="text-xs text-ink-500 uppercase tracking-widest">Endereço</dt>
              <dd class="mt-1 text-ink-950 leading-snug">
                Av. Eduardo Ribeiro, 520 — Sala 02<br/>
                Ed. Manaus Shopping Center, Centro<br/>
                Manaus/AM — CEP 69010-000
              </dd>
            </div>
          </div>

          <div class="flex gap-4">
            <div class="mt-0.5 h-9 w-9 rounded-full bg-paper-pure border border-line flex items-center justify-center text-ton-deep shrink-0">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            </div>
            <div>
              <dt class="text-xs text-ink-500 uppercase tracking-widest">Horário</dt>
              <dd class="mt-1 text-ink-950">Segunda a sábado, 9h às 18h</dd>
            </div>
          </div>

          <div class="flex gap-4">
            <div class="mt-0.5 h-9 w-9 rounded-full bg-paper-pure border border-line flex items-center justify-center text-ton-deep shrink-0">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.5 14.4c-.3-.1-1.7-.8-2-.9-.3-.1-.5-.2-.7.2-.2.3-.8.9-.9 1.1-.2.2-.3.2-.6.1s-1.2-.4-2.3-1.4c-.8-.7-1.4-1.6-1.5-1.9-.2-.3 0-.5.1-.6.1-.1.3-.3.4-.5.1-.2.2-.3.3-.5.1-.2 0-.4 0-.5 0-.1-.7-1.6-.9-2.2-.2-.6-.5-.5-.7-.5h-.6c-.2 0-.5.1-.8.4s-1 1-1 2.5.9 2.9 1.1 3.1c.1.2 2 3.1 4.9 4.3.7.3 1.2.5 1.6.6.7.2 1.3.2 1.8.1.5-.1 1.7-.7 1.9-1.4.2-.7.2-1.3.2-1.4-.1-.2-.3-.2-.7-.4zM12 2.2C6.6 2.2 2.2 6.6 2.2 12c0 1.7.4 3.3 1.2 4.7L2 22l5.5-1.4C8.9 21.4 10.4 21.8 12 21.8c5.4 0 9.8-4.4 9.8-9.8S17.4 2.2 12 2.2z"/></svg>
            </div>
            <div>
              <dt class="text-xs text-ink-500 uppercase tracking-widest">WhatsApp</dt>
              <dd class="mt-1"><a href={wa} target="_blank" rel="noopener" class="text-ink-950 hover:text-ton-deep link-underline">(92) 8460-3260</a></dd>
            </div>
          </div>
        </dl>

        <div class="mt-8 flex flex-wrap gap-3">
          <a href={wa} target="_blank" rel="noopener" class="btn btn-wa" data-cta="store-wa">Chamar no WhatsApp</a>
          <a href="https://maps.google.com/?q=Av.+Eduardo+Ribeiro+520+Manaus" target="_blank" rel="noopener" class="btn btn-ghost">Como chegar</a>
        </div>
      </div>

      <div class="lg:col-span-7">
        <div class="relative aspect-[4/3] rounded-3xl overflow-hidden border border-line bg-paper-pure">
          <iframe
            src="https://www.google.com/maps?q=Av.%20Eduardo%20Ribeiro%2C%20520%20-%20Centro%2C%20Manaus%20-%20AM&output=embed"
            width="100%" height="100%" loading="lazy"
            style="border:0;"
            referrerpolicy="no-referrer-when-downgrade"
            title="Mapa da Loja Parceira Ton Manaus"
          ></iframe>
        </div>
        <div class="mt-4 grid grid-cols-3 gap-3">
          <div class="aspect-[4/3] rounded-xl border border-line bg-paper-pure flex items-center justify-center text-[10px] uppercase tracking-widest text-ink-300">[ fachada ]</div>
          <div class="aspect-[4/3] rounded-xl border border-line bg-paper-pure flex items-center justify-center text-[10px] uppercase tracking-widest text-ink-300">[ balcão ]</div>
          <div class="aspect-[4/3] rounded-xl border border-line bg-paper-pure flex items-center justify-center text-[10px] uppercase tracking-widest text-ink-300">[ atendimento ]</div>
        </div>
      </div>
    </div>
  </div>
</section>
