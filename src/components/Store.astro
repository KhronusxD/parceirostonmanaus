---
const wa = 'https://wa.me/lojatonmanaus?text=' + encodeURIComponent('Olá! Vi a localização no site e quero conversar.');

const unidades = [
  {
    tag: 'Unidade Centro',
    endereco: 'Av. Eduardo Ribeiro, 520, Sala 02',
    complemento: 'Ed. Manaus Shopping Center, Centro',
    cep: 'Manaus/AM, CEP 69010-000',
    horario: 'Seg a sex, 9h às 17h',
    mapaEmbed: 'https://www.google.com/maps?q=Av.%20Eduardo%20Ribeiro%2C%20520%20-%20Centro%2C%20Manaus%20-%20AM&output=embed',
    mapaLink: 'https://maps.google.com/?q=Av.+Eduardo+Ribeiro+520+Manaus',
  },
  {
    tag: 'Unidade Cidade Nova',
    endereco: 'Rua Felix Valois, 41',
    complemento: 'Cidade Nova, perto da Blue Fit',
    cep: 'Manaus/AM',
    horario: 'Seg a sex, 9h às 17h',
    mapaEmbed: 'https://www.google.com/maps?q=Rua%20Felix%20Valois%2041%2C%20Cidade%20Nova%2C%20Manaus%20-%20AM&output=embed',
    mapaLink: 'https://maps.google.com/?q=Rua+Felix+Valois+41+Cidade+Nova+Manaus',
  }
];
---
<section id="loja" class="relative py-24 md:py-32 bg-paper-soft">
  <div class="container-x">
    <div class="max-w-3xl mx-auto text-center">
      <span class="eyebrow">06 · Loja física</span>
      <h2 class="mt-3 text-3xl md:text-5xl font-bold text-ink-950">
        Duas lojas em Manaus. E vamos até você.
      </h2>
      <p class="mt-5 text-ink-500 text-base md:text-lg leading-relaxed">
        Passe em qualquer uma das nossas lojas pra ver o aparelho na mão. Ou peça a entrega no seu comércio ou residência,
        em qualquer bairro de Manaus. Ativação assistida em qualquer caso.
      </p>
    </div>

    <div class="mt-12 grid grid-cols-1 md:grid-cols-2 gap-6 max-w-5xl mx-auto">
      {unidades.map((u) => (
        <div class="card overflow-hidden flex flex-col">
          <div class="relative aspect-[4/3] bg-paper-soft">
            <iframe
              src={u.mapaEmbed}
              width="100%" height="100%" loading="lazy"
              style="border:0;"
              referrerpolicy="no-referrer-when-downgrade"
              title={`Mapa da ${u.tag}`}
            ></iframe>
          </div>
          <div class="p-6 md:p-7 flex-1 flex flex-col">
            <span class="eyebrow">{u.tag}</span>
            <div class="mt-3 text-ink-950 leading-snug">
              <strong class="font-semibold">{u.endereco}</strong><br/>
              <span class="text-ink-700">{u.complemento}</span><br/>
              <span class="text-ink-500 text-sm">{u.cep}</span>
            </div>
            <div class="mt-4 flex items-center gap-2 text-sm text-ink-700">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-ton-deep"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
              {u.horario}
            </div>
            <div class="mt-6 flex flex-wrap gap-2 pt-4 border-t border-line">
              <a href={wa} target="_blank" rel="noopener" class="btn btn-wa text-xs px-4 py-2.5" data-cta={`store-wa-${u.tag.toLowerCase().replace(/\s+/g,'-')}`}>WhatsApp</a>
              <a href={u.mapaLink} target="_blank" rel="noopener" class="btn btn-ghost text-xs px-4 py-2.5">Como chegar</a>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
