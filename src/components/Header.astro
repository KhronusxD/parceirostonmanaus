---
const wa = 'https://wa.me/lojatonmanaus?text=' + encodeURIComponent('Olá! Vim pelo site e quero saber sobre as maquininhas Ton.');
---
<header class="relative z-30 sticky top-0 bg-paper/85 backdrop-blur-md border-b border-line/70">
  <div class="container-x flex items-center justify-between py-4">
    <a href="/" class="flex items-center gap-3" aria-label="Loja Parceira Ton Manaus">
      <img src="/logo-ton.png" alt="ton" width="52" height="40" class="h-9 w-auto" />
      <span class="flex flex-col leading-tight border-l border-line pl-3">
        <span class="font-display text-sm font-semibold text-ink-950">Loja Parceira</span>
        <span class="font-mono text-[10px] uppercase tracking-widest text-ton-deep">Manaus • Centro</span>
      </span>
    </a>

    <nav class="hidden md:flex items-center gap-7 text-sm text-ink-700">
      <a href="#modelos" class="link-underline">Modelos</a>
      <a href="#planos" class="link-underline">Planos</a>
      <a href="#por-que" class="link-underline">Por que aqui</a>
      <a href="#loja" class="link-underline">Loja</a>
      <a href="#faq" class="link-underline">FAQ</a>
    </nav>

    <a href={wa} target="_blank" rel="noopener" class="btn btn-wa text-xs md:text-sm px-4 md:px-6 py-2.5" data-cta="header-wa">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M17.5 14.4c-.3-.1-1.7-.8-2-.9-.3-.1-.5-.2-.7.2-.2.3-.8.9-.9 1.1-.2.2-.3.2-.6.1s-1.2-.4-2.3-1.4c-.8-.7-1.4-1.6-1.5-1.9-.2-.3 0-.5.1-.6.1-.1.3-.3.4-.5.1-.2.2-.3.3-.5.1-.2 0-.4 0-.5 0-.1-.7-1.6-.9-2.2-.2-.6-.5-.5-.7-.5h-.6c-.2 0-.5.1-.8.4s-1 1-1 2.5.9 2.9 1.1 3.1c.1.2 2 3.1 4.9 4.3.7.3 1.2.5 1.6.6.7.2 1.3.2 1.8.1.5-.1 1.7-.7 1.9-1.4.2-.7.2-1.3.2-1.4-.1-.2-.3-.2-.7-.4zM12 2.2C6.6 2.2 2.2 6.6 2.2 12c0 1.7.4 3.3 1.2 4.7L2 22l5.5-1.4C8.9 21.4 10.4 21.8 12 21.8c5.4 0 9.8-4.4 9.8-9.8S17.4 2.2 12 2.2z"/>
      </svg>
      WhatsApp
    </a>
  </div>
</header>
